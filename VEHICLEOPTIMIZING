    local function SetNoclip(state)
        F.Noclip=state
        local Vehicle=Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then return end
        if state then
            if not F.NoclipForce then
                pcall(function()
                    local att=Instance.new("Attachment"); att.Name="VoxNoclipAtt"; att.Parent=Vehicle.PrimaryPart
                    local vf=Instance.new("VectorForce"); vf.ApplyAtCenterOfMass=true; vf.Attachment0=att
                    vf.Force=Vector3.new(0,Workspace.Gravity*Vehicle.PrimaryPart:GetMass(),0)
                    vf.Parent=Vehicle.PrimaryPart; F.NoclipForce=vf; F.NoclipAtt=att
                end)
            end
        else
            if F.NoclipForce then pcall(function() F.NoclipForce:Destroy() end); F.NoclipForce=nil end
            if F.NoclipAtt   then pcall(function() F.NoclipAtt:Destroy()   end); F.NoclipAtt=nil end
            pcall(function()
                for _,p in pairs(Internal.PartsCache) do if p and p.Parent then p.CanCollide=true end end
            end)
        end
        Notif("Noclip",state and "Enabled!" or "Disabled!")
    end

