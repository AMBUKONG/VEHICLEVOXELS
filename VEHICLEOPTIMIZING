    local function SetHeli(en)
        if F.HeliConn then F.HeliConn:Disconnect(); F.HeliConn=nil end
        F.HeliEnabled=en
        if en then
            F.HeliConn=RunService.Heartbeat:Connect(function()
                pcall(function()
                    if Internal.Vehicle and Internal.Vehicle.PrimaryPart then
                        Internal.Vehicle:SetPrimaryPartCFrame(
                            Internal.Vehicle:GetPrimaryPartCFrame()*CFrame.Angles(0,math.rad(F.HeliSpeed),0))
                    end
                end)
            end)
            Notif("Helicopter","Enabled!")
        else Notif("Helicopter","Disabled!") end
    end

    local function FBSave()
        F.FBOriginal={Brightness=Lighting.Brightness,ClockTime=Lighting.ClockTime,
            FogEnd=Lighting.FogEnd,OutdoorAmbient=Lighting.OutdoorAmbient,
            ColorShift_Top=Lighting.ColorShift_Top,ColorShift_Bottom=Lighting.ColorShift_Bottom}
    end
    local function FBApply()
        Lighting.Brightness=F.FBBrightness; Lighting.ClockTime=14; Lighting.FogEnd=F.FBFogEnd
        Lighting.OutdoorAmbient=F.FBAmbient; Lighting.ColorShift_Top=F.FBAmbient; Lighting.ColorShift_Bottom=F.FBAmbient
    end
    local function SetFB(en)
