    local connections = {}


    local Internal = {
        Vehicle          = nil,
        Seat             = nil,
        IsDriver         = false,
        PartsCache       = {},
        VehicleMass      = 0,
        LastNotifTime    = 0,
    }

    local SuspCache = {
        Springs        = {},
        OriginalValues = {},
        SpringCount    = 0,
    }

    local SuspData = {
        Enabled        = false,
        OrigBaseHeight = 0,

        -- All tuning is 0-100 on sliders; these are the live values
        -- Stiffness / Damping are MULTIPLIERS on the vehicle's original spring values
        -- so the car always stays in a physically stable range
        StiffMult      = 1.0,    -- 0.1 (super soft) → 3.0 (very stiff), slider 0-100 → 0.1-3.0
        DampMult       = 1.0,    -- 0.1 → 3.0, same scale
        FrontBias      = 0.0,    -- -1..1: negative = softer front, positive = stiffer front
        RearBias       = 0.0,    -- -1..1: negative = softer rear,  positive = stiffer rear

        -- Ride height: small offsets on FreeLength (studs). Max ±1.5 st.
        Height         = 0.0,   -- slider -100..100 → -1.5..1.5 studs
        Preload        = 0.0,   -- slider -50..50   → -0.5..0.5 studs
        CurrentHeight  = 0.0,

        -- ARB
        ARB            = false,
        ARB_Str        = 0.3,    -- 0..1, slider 0-100
        DriftMode      = false,

        -- Hydraulics
        HydroEnabled   = false,
        HydroPressure  = 1.0,
        HydroSpeed     = 0.05,

        -- Bounce
        BounceEnabled  = false,
        BounceAmplitude= 0.05,   -- studs, kept tiny
        BounceFreq     = 2.0,
        BouncePhase    = 0,

        -- Realistic weight transfer (FreeLength offsets, capped very small)
        SquatEnabled   = true,
        SquatAmt       = 0.06,   -- max stud offset (rear compresses under accel)
        DiveEnabled    = true,
        DiveAmt        = 0.06,   -- max stud offset (front compresses under braking)
        RollEnabled    = true,
        RollAmt        = 0.05,   -- max stud offset per side (body roll)

        -- Speed-sensitive damping
        SpeedDamping   = true,
        SpeedDampMax   = 1.6,    -- max damping multiplier at high speed
        SpeedRef       = 80,     -- st/s where full extra damping kicks in

        -- Live weight transfer state (lerped, -1..1)
        FrontLoad      = 0.0,
        RearLoad       = 0.0,
        LatLoad        = 0.0,
        PrevLongV      = 0.0,
        PrevLatV       = 0.0,
        LoadLerp       = 0.08,   -- lerp rate (lower = slower / more inertia)
    }

    -- ──────────────────────────────────────────────────────────
    -- SUSPENSION FORCE — Spring-Damper per wheel via raycast
    --
    -- Each wheel gets ONE VectorForce.  Every Heartbeat we:
    --   1. Raycast straight down from the wheel centre
    --   2. Compute compression = restHeight - currentDist
    --   3. springForce  = stiffness * compression   (only if compressed)
    --   4. damperForce  = -damping  * wheel.velY    (always, resists motion)
    --   5. Clamp total to [0, maxForce] so we NEVER push down or launch
    --
    -- When the car is already at/above rest height → compression ≤ 0
    -- → springForce = 0, only light damping → gravity pulls it back.
    -- This prevents flying.
    -- ──────────────────────────────────────────────────────────
    local SuspForce = {
        Enabled     = false,
        WheelData   = {},      -- {part, isFront, side, att, vf}

        RestHeight  = 2.0,     -- studs from wheel centre to ground at rest
        FrontStiff  = 800,     -- spring stiffness (N/stud) — front
        RearStiff   = 800,     -- spring stiffness (N/stud) — rear
        Damping     = 120,     -- damper coefficient (N·s/stud)
        MaxForce    = 50000,   -- hard cap per wheel (N) — prevents flying
        SideBalance = 0,       -- -100…+100 % left/right bias

        -- live readout (updated each frame)
        LiveForces  = {},      -- [i] = N applied this frame
        LiveCompr   = {},      -- [i] = compression this frame (studs)
    }

    local SUSP_NAMES_BLACKLIST = {
        "voxsuspforceatt","voxsuspforce","voxnoclipatt","voxgravatt"
    }

    local function ClearSuspForces()
        for _, wd in pairs(SuspForce.WheelData) do
            pcall(function() if wd.att and wd.att.Parent then wd.att:Destroy() end end)
        end
        SuspForce.WheelData  = {}
        SuspForce.LiveForces = {}
        SuspForce.LiveCompr  = {}
    end

    -- ── Wheel detection for SuspForce ──────────────────────────
    local WHL_KW = {
        "wheel","tire","tyre","rim","rubber","w1","w2","w3","w4","w5","w6",
        "fl","fr","rl","rr","lf","rf","lr","rr",
        "frontleft","frontright","rearleft","rearright",
        "leftfront","rightfront","leftrear","rightrear",
        "frontwheel","rearwheel","backwheel","backrim",
        "leftwheel","rightwheel","hubcap","axle","hub",
        "steerwheel","drivewheel","driven",
    }
    local WHL_BAD = {
        "brake","caliper","disc","rotor","piston","suspension","susp",
        "damper","spring","seat","cabin","bumper","hood","trunk","roof",
        "light","lamp","window","glass","mirror","exhaust","engine",
        "interior","dash","frame","chassis","body",
    }

    local function IsWheelName(name)
        local n = name:lower()
        for _,kw in pairs(WHL_BAD) do if n:find(kw,1,true) then return false end end
        for _,kw in pairs(WHL_KW)  do if n:find(kw,1,true) then return true  end end
        return false
    end

    local function ScoreWheelPartSF(part, primCF)
        local n = part.Name:lower()
        local score = 0
        for _,kw in pairs(WHL_BAD) do if n:find(kw,1,true) then return -999 end end
        for _,kw in pairs(WHL_KW)  do if n:find(kw,1,true) then score=score+12; break end end

        if part:IsA("BasePart") then
            if part:IsA("Part") and part.Shape==Enum.PartType.Cylinder then score=score+20 end
            local sz  = part.Size
            local mn  = math.min(sz.X,sz.Y,sz.Z)
            local mx  = math.max(sz.X,sz.Y,sz.Z)
            local rat = mx/(mn+0.001)
            if rat > 1.4  then score=score+8  end   -- flat disc shape
            if rat > 2.0  then score=score+5  end   -- very flat = cylinder
            if sz.Magnitude > 0.2 and sz.Magnitude < 12 then score=score+4 end
        end

        -- Check for cylinder/sphere mesh
        for _,child in pairs(part:GetChildren()) do
            if child:IsA("SpecialMesh") then
                local mt = child.MeshType
                if mt==Enum.MeshType.Cylinder or mt==Enum.MeshType.Sphere then score=score+18 end
                local mid = child.MeshId:lower()
                if mid:find("wheel",1,true) or mid:find("tire",1,true) then score=score+10 end
            end
        end

        -- Lateral offset from vehicle centre (wheels are off-centre)
        local lp = primCF:PointToObjectSpace(part.Position)
        local absX = math.abs(lp.X)
        if absX > 0.5 then score=score+6  end
        if absX > 1.5 then score=score+4  end
        if absX > 3.0 then score=score+2  end
        -- Height: wheels near ground
        if math.abs(lp.Y) < 3 then score=score+5 end

        return score
    end

    local function DetectWheelsSF(Vehicle)
        local wheels  = {}
        local seen    = {}
        local primCF  = Vehicle.PrimaryPart and Vehicle.PrimaryPart.CFrame
                        or CFrame.new(Vehicle:GetPivot().Position)

        -- Pass 1: score every BasePart
        local scored = {}
        for _,p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                local ok,sc = pcall(ScoreWheelPartSF,p,primCF)
                if ok and sc >= 8 then
                    table.insert(scored,{part=p, score=sc})
                end
            end
        end
        table.sort(scored,function(a,b) return a.score > b.score end)

        local function AddW(part)
            if seen[part] then return end
            seen[part] = true
            local lp    = primCF:PointToObjectSpace(part.Position)
            table.insert(wheels,{
                part    = part,
                isFront = lp.Z > 0,
                side    = lp.X > 0 and 1 or -1,
                att     = nil,
                vf      = nil,
            })
        end

        -- Pass 2: joint-connected wheels (most reliable)
        for _,obj in pairs(Vehicle:GetDescendants()) do
            if obj:IsA("Weld") or obj:IsA("Motor6D") then
                local ok,p0,p1 = pcall(function() return obj.Part0,obj.Part1 end)
                if ok then
                    for _,p in pairs({p0,p1}) do
                        if p and not seen[p] then
                            local ok2,sc = pcall(ScoreWheelPartSF,p,primCF)
                            if ok2 and sc >= 8 then AddW(p) end
                        end
                    end
                end
            elseif obj:IsA("WeldConstraint") then
                local p0,p1; pcall(function() p0=obj.Part0; p1=obj.Part1 end)
                for _,p in pairs({p0,p1}) do
                    if p and not seen[p] then
                        local ok2,sc = pcall(ScoreWheelPartSF,p,primCF)
                        if ok2 and sc >= 8 then AddW(p) end
                    end
                end
            end
        end

        -- Pass 3: top scored parts not yet added
        for _,entry in ipairs(scored) do
            if not seen[entry.part] then
                AddW(entry.part)
            end
        end

        -- Pass 4: corner fallback — guarantee at least one part per corner
        local function HasCorner(isFront, side)
            for _,w in pairs(wheels) do
                if w.isFront==isFront and w.side==side then return true end
            end
            return false
        end
        local CORNERS={{true,1},{true,-1},{false,1},{false,-1}}
        for _,c in pairs(CORNERS) do
            if not HasCorner(c[1],c[2]) then
                local best,bestSc = nil,-math.huge
                for _,p in pairs(Vehicle:GetDescendants()) do
                    if p:IsA("BasePart") and not seen[p] then
                        local lp=primCF:PointToObjectSpace(p.Position)
                        local isFr=lp.Z>0; local sd=lp.X>0 and 1 or -1
                        if isFr==c[1] and sd==c[2] then
                            local n=p.Name:lower()
                            local blocked=false
                            for _,kw in pairs(WHL_BAD) do if n:find(kw,1,true) then blocked=true;break end end
                            if not blocked then
                                local sc = math.abs(lp.X)*3 - math.abs(lp.Y)
                                if p:IsA("Part") and p.Shape==Enum.PartType.Cylinder then sc=sc+25 end
                                if sc > bestSc then bestSc=sc; best=p end
                            end
                        end
                    end
                end
                if best then AddW(best) end
            end
        end

        -- Remove centre stray if odd count
        if #wheels > 0 and #wheels % 2 ~= 0 then
            local wi,wax = nil,math.huge
            for i,w in ipairs(wheels) do
                local lp=primCF:PointToObjectSpace(w.part.Position)
                if math.abs(lp.X) < wax then wax=math.abs(lp.X); wi=i end
            end
            if wi then table.remove(wheels,wi) end
        end

        return wheels
    end

    local function BuildSuspForces()
        ClearSuspForces()
        local Vehicle = Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then return end

        local wlist = DetectWheelsSF(Vehicle)
        for i,wd in ipairs(wlist) do
            pcall(function()
                local att = Instance.new("Attachment")
                att.Name   = "VoxSuspForceAtt"
                att.Parent = wd.part

                local vf = Instance.new("VectorForce")
                vf.Name                = "VoxSuspForce"
                vf.ApplyAtCenterOfMass = true
                vf.RelativeTo          = Enum.ActuatorRelativeTo.World
                vf.Attachment0         = att
                vf.Force               = Vector3.zero   -- starts at ZERO
                vf.Parent              = wd.part

                wd.att = att
                wd.vf  = vf
                table.insert(SuspForce.WheelData, wd)
                SuspForce.LiveForces[#SuspForce.WheelData] = 0
                SuspForce.LiveCompr [#SuspForce.WheelData] = 0
            end)
        end
        SysNotif("Floating Vehicle","Active on "..#SuspForce.WheelData.." wheel(s)",3)
    end

    -- ── Spring-damper tick called every Heartbeat ───────────────
    local _sfParams = RaycastParams.new()
    _sfParams.FilterType = Enum.RaycastFilterType.Exclude

    local function SuspForceTick()
        if not SuspForce.Enabled then return end
        local Vehicle = Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then return end

        -- Keep exclusion list current (cheap: same reference is ok)
        _sfParams.FilterDescendantsInstances = {Vehicle}

        for i, wd in ipairs(SuspForce.WheelData) do
            pcall(function()
                local part = wd.part
                if not part or not part.Parent then return end
                local vf  = wd.vf
                if not vf or not vf.Parent then return end

                -- Raycast from wheel centre downward
                -- Offset origin slightly UP so we don't start inside ground
                local origin = part.Position + Vector3.new(0, 0.3, 0)
                local castLen = SuspForce.RestHeight + 3   -- search a bit past rest
                local result  = Workspace:Raycast(origin, Vector3.new(0, -castLen, 0), _sfParams)

                local totalF = 0
                local compr  = 0

                if result then
                    local groundY  = result.Position.Y
                    local wheelY   = part.Position.Y
                    local dist     = wheelY - groundY        -- current dist to ground
                    compr          = SuspForce.RestHeight - dist  -- positive = compressed

                    -- Spring force only when compressed (prevents lifting too high)
                    local stiff  = wd.isFront and SuspForce.FrontStiff or SuspForce.RearStiff
                    local springF = compr > 0 and (stiff * compr) or 0

                    -- Velocity damping (opposes vertical motion, both up and down)
                    local velY   = part.AssemblyLinearVelocity.Y
                    local damperF = -SuspForce.Damping * velY

                    -- Side balance multiplier
                    local bal = 1.0
                    if SuspForce.SideBalance ~= 0 then
                        local n = SuspForce.SideBalance / 100
                        bal = wd.side == -1
                            and math.clamp(1 + n, 0.01, 4)
                            or  math.clamp(1 - n, 0.01, 4)
                    end

                    -- Clamp: never negative (no sucking down), never above MaxForce
                    totalF = math.clamp((springF + damperF) * bal, 0, SuspForce.MaxForce)
                end

                vf.Force = Vector3.new(0, totalF, 0)
                SuspForce.LiveForces[i] = math.floor(totalF)
                SuspForce.LiveCompr [i] = math.floor(compr * 100) / 100
            end)
        end
    end

