KVerify.MouseButton1Click:Connect(function()
    if KBox.Text==CORRECT_KEY then
        LoadMainScript()
    else
        local origPos=KFrame.Position; KBox.Text=""
        SysNotif("Vehicle Voxels","Incorrect key!",2)
        task.spawn(function()
            TweenService:Create(KVerify,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(200,50,50)}):Play()
            for _,offset in ipairs({-14,14,-10,10,-5,5,0}) do
                TweenService:Create(KFrame,TweenInfo.new(0.06),
                    {Position=origPos+UDim2.new(0,offset,0,0)}):Play()
                task.wait(0.06)
            end
            task.wait(0.4)
            TweenService:Create(KVerify,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
        end)
    end
end)

