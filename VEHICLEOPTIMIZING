    local SusCoreGrp = SusCorePage:Groupbox("Core Settings","Left")
    SusCoreGrp:AddToggle({ Title="Enable Suspension Override", Default=false, Flag="SuspEnabled", Risky=true,
        Callback=function(v)
            SuspData.Enabled=v
            if v then
                if SuspCache.SpringCount > 0 then
                    local sum,count,stiffSum,dampSum=0,0,0,0
                    for _, orig in pairs(SuspCache.OriginalValues) do
                        sum=sum+orig.FreeLength; stiffSum=stiffSum+orig.Stiffness; dampSum=dampSum+orig.Damping; count=count+1
                    end
                    if count>0 then
                        SuspData.OrigBaseHeight=sum/count; SuspData.CurrentHeight=SuspData.OrigBaseHeight
                        SuspData.FrontStiff=stiffSum/count; SuspData.RearStiff=stiffSum/count; SuspData.Damping=dampSum/count
                    end
                end
                Notif("Suspension","Override ON")
            else
                for i=1,#SuspCache.Springs do
                    local spring=SuspCache.Springs[i]
                    if spring and spring.Parent then
                        local orig=SuspCache.OriginalValues[spring]
                        if orig then
                            pcall(function()
                                spring.Stiffness=orig.Stiffness; spring.Damping=orig.Damping
                                spring.FreeLength=orig.FreeLength; spring.MinLength=orig.MinLength; spring.MaxLength=orig.MaxLength
                            end)
                        end
                    end
                end
                Notif("Suspension","Override OFF — springs restored")
            end
        end })
