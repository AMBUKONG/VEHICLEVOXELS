do
    local dragging   = false
    local dragStart  = Vector2.zero   -- mouse pos at drag begin
    local frameStart = Vector2.zero   -- KFrame absolute pos at drag begin

    -- InputBegan on KFrame captures the drag start
    KFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging   = true
            dragStart  = Vector2.new(input.Position.X, input.Position.Y)
            -- Snapshot current absolute position
            frameStart = Vector2.new(KFrame.AbsolutePosition.X, KFrame.AbsolutePosition.Y)
        end
    end)

    -- InputEnded on UserInputService so we catch mouse-up anywhere on screen
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Move on mouse movement
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart
            local newX  = frameStart.X + delta.X
            local newY  = frameStart.Y + delta.Y

            -- Keep the window fully on-screen
            local vp   = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize
                         or Vector2.new(1920, 1080)
            local fw   = KFrame.AbsoluteSize.X
            local fh   = KFrame.AbsoluteSize.Y
            newX = math.clamp(newX, 0, vp.X - fw)
            newY = math.clamp(newY, 0, vp.Y - fh)

            -- Use Scale=0 offset-only positioning so it doesn't fight the tween anchor
            KFrame.Position = UDim2.new(0, newX, 0, newY)
            -- Also move the shadow to match
            Shadow.Position = UDim2.new(0, newX - 12, 0, newY - 12)
        end
    end)

    -- Prevent dragging when clicking text inputs / buttons inside the frame
    local function blockDrag(obj)
        obj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end
    blockDrag(KBox)
    blockDrag(KVerify)
    blockDrag(KGetKey)
    blockDrag(KClose)
end

