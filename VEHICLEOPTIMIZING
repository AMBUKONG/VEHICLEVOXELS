    -- ──────────────────────────────────────────────────────────
    -- THEME READABILITY SYSTEM
    --
    -- After any theme change we scan every TextLabel and TextButton
    -- inside the Library GUI and enforce a contrast-safe text colour.
    --
    -- Algorithm:
    --   1. Grab the background colour from Library.Theme (fallback black).
    --   2. Compute relative luminance (WCAG formula).
    --   3. If background is LIGHT  → text = very dark  (#0D0D0D)
    --      If background is DARK   → text = off-white  (#F0F0F0)
    --   4. Push the result through Library:UpdateTheme for every known
    --      text-related theme key, then walk every descendant TextLabel /
    --      TextButton inside the library GUI and fix them directly so
    --      nothing is missed regardless of what the Library calls its keys.
    -- ──────────────────────────────────────────────────────────
    local function GetLuminance(c)
        local function lin(v)
            v = v / 255  -- Color3 channels are already 0-1, pass raw
            return v <= 0.03928 and v/12.92 or ((v+0.055)/1.055)^2.4
        end
        return 0.2126*lin(c.R*255) + 0.7152*lin(c.G*255) + 0.0722*lin(c.B*255)
    end

    local function EnforceReadability()
        task.defer(function()   -- defer so Library finishes applying the theme first
            pcall(function()
                -- 1. Determine background luminance
                local bg  = (Library.Theme and Library.Theme.Background)
                            or Color3.fromRGB(12,12,12)
                local lum = GetLuminance(bg)

                -- 2. Pick text colours that always contrast
                local isLight   = lum > 0.35
                local mainText  = isLight
                    and Color3.fromRGB(13,  13,  13 )   -- near-black for light themes
                    or  Color3.fromRGB(240, 240, 240)   -- off-white for dark themes
                local subText   = isLight
                    and Color3.fromRGB(50,  50,  50 )
                    or  Color3.fromRGB(170, 170, 170)
                local labelText = isLight
                    and Color3.fromRGB(30,  30,  30 )
                    or  Color3.fromRGB(200, 200, 200)

                -- 3. Push through Library theme keys (covers future Library renders)
                if Library.UpdateTheme then
                    for _, key in ipairs({"Text","TextDark","SubText","PlaceHolder"}) do
                        local col = (key == "SubText" or key == "PlaceHolder") and subText or mainText
                        pcall(function() Library:UpdateTheme(key, col) end)
                    end
                end

                -- 4. Walk every GUI descendant and fix text directly
                --    This catches elements already rendered that UpdateTheme missed.
                local libGui = CoreGui:FindFirstChild("RedOnyx")
                             or CoreGui:FindFirstChild("LinoriaLib")
                             or CoreGui:FindFirstChild("Library")
                if libGui then
                    for _, obj in ipairs(libGui:GetDescendants()) do
                        pcall(function()
                            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                                -- Skip elements that deliberately use accent/highlight colour
                                -- (identified by being fully opaque and using the accent bg)
                                local parentBg = obj.Parent and obj.Parent:IsA("Frame")
                                    and not (obj.Parent.BackgroundTransparency >= 0.9)

                                -- Only override if text is invisible against its own background
                                local tc = obj.TextColor3
                                local tLum = GetLuminance(tc)
                                -- Get effective bg: check parent frame bg, else use theme bg
                                local effectiveBg = bg
                                if obj.Parent and obj.Parent:IsA("Frame") then
                                    local pb = obj.Parent.BackgroundTransparency
                                    if pb < 0.5 then
                                        effectiveBg = obj.Parent.BackgroundColor3
                                    end
                                end
                                local bgLum2 = GetLuminance(effectiveBg)
                                -- Contrast ratio = (lighter+0.05)/(darker+0.05)
                                local lighter = math.max(tLum, bgLum2)
                                local darker  = math.min(tLum, bgLum2)
                                local contrast = (lighter + 0.05) / (darker + 0.05)

                                -- WCAG AA requires 4.5:1 for normal text.
                                -- We use a slightly lower bar (3.5) to avoid fighting styled highlights.
                                if contrast < 3.5 then
                                    -- Choose whichever text colour gives better contrast vs this bg
                                    local darkContrast  = (bgLum2 + 0.05) / (GetLuminance(Color3.fromRGB(13,13,13))  + 0.05)
                                    local lightContrast = (GetLuminance(Color3.fromRGB(240,240,240)) + 0.05) / (bgLum2 + 0.05)
                                    if lightContrast >= darkContrast then
                                        obj.TextColor3 = Color3.fromRGB(240,240,240)
                                    else
                                        obj.TextColor3 = Color3.fromRGB(13,13,13)
                                    end
                                end
                            end
                        end)
                    end
                end
            end)
        end)
    end

    local ThG=SetP:Groupbox("Theme","Right")
    if Library.ThemePresets then
        local tl={}; for k in pairs(Library.ThemePresets) do table.insert(tl,k) end; table.sort(tl)
        ThG:AddDropdown({Title="Preset Theme",Values=tl,Default="Default",Multi=false,
            Callback=function(v)
                if Library.SetTheme then Library:SetTheme(v) end
                EnforceReadability()
            end})
        ThG:AddSeparator()
    end
    ThG:AddColorPicker({Title="Accent Color",Default=Library.Theme and Library.Theme.Accent or Color3.new(1,1,1),Flag="ThemeAccent",
        Callback=function(c)
            Library:UpdateTheme("Accent",c)
            EnforceReadability()
        end})
    ThG:AddColorPicker({Title="Background",Default=Library.Theme and Library.Theme.Background or Color3.new(0,0,0),Flag="ThemeBG",
        Callback=function(c)
            Library:UpdateTheme("Background",c)
            EnforceReadability()
        end})
    ThG:AddButton({Title="Reset Theme",Callback=function()
        if Library.SetTheme then Library:SetTheme("Default") end
        EnforceReadability()
    end})
    ThG:AddSeparator()
    ThG:AddButton({Title="Fix Text Visibility (manual)",Callback=function()
        EnforceReadability()
        Notif("Theme","Text readability enforced!",2)
    end})
    local UIG=SetP:Groupbox("UI Settings","Right")
    UIG:AddToggle({Title="Show Watermark",Default=true,Flag="WatermarkToggle",
        Callback=function(v) if Library.WatermarkSettings then Library.WatermarkSettings.Enabled=v end end})
    UIG:AddTextbox({Title="Watermark Text",Default="Vehicle Voxels",Placeholder="Enter text…",ClearOnFocus=false,
        Callback=function(v) if Library.WatermarkSettings then Library.WatermarkSettings.Text=v end end})

    table.insert(connections, UserInputService.InputBegan:Connect(function(inp,gpe)
        if not gpe and inp.KeyCode==Enum.KeyCode.RightBracket then
            pcall(function() if Library.Toggle then Library:Toggle() end end)
        end
    end))

    Notif("Vehicle Voxels","Loaded!  Key ] = toggle UI.",4)
end

