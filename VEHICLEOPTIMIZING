    local function SafeUnit(v)
        return v.Magnitude > 1e-5 and v.Unit or Vector3.new(0,0,0)
    end

    -- ============================================================
    -- CAMBER WHEEL DETECTION
    -- ============================================================
    local WHEEL_KW = {
        "wheel","tire","tyre","rim","rubber","tires","wheels",
        "fl","fr","rl","rr","lf","rf","lr",
        "frontleft","frontright","rearleft","rearright",
        "wheelmesh","cylindermesh","w1","w2","w3","w4","w5","w6",
        "leftwheel","rightwheel","frontwheel","rearwheel",
        "hubcap","axlewheel","drivewheel","steerwheel",
        "back_wheel","front_wheel","rear_wheel",
        "backwheel","backrim","rearrim","frontrim",
        "axle","hub",
    }
    local NONWHEEL_KW = {
        "brake","caliper","disc","rotor","piston",
        "suspension","susp","damper","spring",
        "seat","cabin","bumper","hood","trunk","roof",
        "light","lamp","window","glass","mirror",
    }

    local function IsWheelName(name)
        local n = name:lower()
        for _, kw in pairs(NONWHEEL_KW) do
            if n:find(kw, 1, true) then return false end
        end
        for _, kw in pairs(WHEEL_KW) do
            if n:find(kw, 1, true) then return true end
        end
        return false
    end

    local function ScoreWheelPart(part, primCF)
        local score = 0
        local n     = part.Name:lower()
        for _, kw in pairs(NONWHEEL_KW) do
            if n:find(kw, 1, true) then return -999 end
        end
        for _, kw in pairs(WHEEL_KW) do
            if n:find(kw, 1, true) then score = score + 10; break end
        end
        if part:IsA("BasePart") then
            if part:IsA("Part") and part.Shape == Enum.PartType.Cylinder then
                score = score + 15
            end
            local sz    = part.Size
            local minS  = math.min(sz.X, sz.Y, sz.Z)
            local maxS  = math.max(sz.X, sz.Y, sz.Z)
            local ratio = maxS / (minS + 0.001)
            if ratio > 1.5 then score = score + 8 end
            if sz.Magnitude > 0.3 and sz.Magnitude < 10 then score = score + 3 end
        end
        for _, child in pairs(part:GetChildren()) do
            if child:IsA("SpecialMesh") then
                local mt = child.MeshType
                if mt == Enum.MeshType.Cylinder or mt == Enum.MeshType.Sphere then
                    score = score + 12
                end
                local cid = child.MeshId:lower()
                if cid:find("wheel",1,true) or cid:find("tire",1,true) then
                    score = score + 8
                end
            end
        end
        local localPos = primCF:PointToObjectSpace(part.Position)
        if math.abs(localPos.X) > 0.8 then score = score + 5 end
        if math.abs(localPos.Y) < 2.5  then score = score + 3 end
        return score
    end

    local function CacheWheels(Vehicle)
        CamberData.Wheels = {}
        if not Vehicle or not Vehicle.PrimaryPart then return end
        local primCF    = Vehicle.PrimaryPart.CFrame
        local seenParts = {}
        local candidates = {}

        -- Pass 1: score all BaseParts
        pcall(function()
            for _, obj in pairs(Vehicle:GetDescendants()) do
                if obj:IsA("BasePart") then
                    local ok, score = pcall(ScoreWheelPart, obj, primCF)
                    if ok and score >= 5 then
                        candidates[obj] = score
                    end
                end
            end
        end)

        local function AddWheel(part, joint, origC0, isDirect, useC1)
            if seenParts[part] then return end
            seenParts[part] = true
            local localPos = primCF:PointToObjectSpace(part.Position)

            -- BAKE CAMBER AXIS:
            -- Camber tilts the wheel around its spin axis (the axle running
            -- left-right across the car). We find this by projecting the
            -- vehicle's RIGHT vector into the joint offset's local space.
            -- We also try FORWARD, then pick whichever is more horizontal
            -- in offset space (smaller Y = more axle-like), so this works
            -- on vehicles that mount wheels in non-standard orientations.
            local camberAxis = Vector3.new(1, 0, 0)  -- safe fallback
            local parentPart = nil
            if joint then
                pcall(function()
                    parentPart = useC1 and joint.Part1 or joint.Part0
                end)
            end
            if joint and origC0 and parentPart then
                pcall(function()
                    if not parentPart.Parent then return end

                    local r = origC0.RightVector
                    local u = origC0.UpVector
                    local l = origC0.LookVector

                    -- Project vehicle RIGHT into offset local space
                    local rightInParent = parentPart.CFrame:VectorToObjectSpace(primCF.RightVector)
                    local rightInOffset = Vector3.new(
                        rightInParent:Dot(r), rightInParent:Dot(u), rightInParent:Dot(l))

                    -- Project vehicle FORWARD into offset local space
                    local fwdInParent = parentPart.CFrame:VectorToObjectSpace(primCF.LookVector)
                    local fwdInOffset = Vector3.new(
                        fwdInParent:Dot(r), fwdInParent:Dot(u), fwdInParent:Dot(l))

                    -- Pick the candidate whose Y component is smaller
                    -- (more horizontal = more axle-aligned = better tilt axis)
                    local candidate = (math.abs(rightInOffset.Y) <= math.abs(fwdInOffset.Y))
                        and rightInOffset or fwdInOffset

                    if candidate.Magnitude > 0.001 then
                        camberAxis = candidate.Unit
                    end
                end)
            end

            table.insert(CamberData.Wheels, {
                Part         = part,
                Joint        = joint,
                OrigC0       = origC0,
                UseC1        = useC1 or false,
                ParentPart   = parentPart,
                CamberAxis   = camberAxis,
                IsFront      = localPos.Z > 0,
                Side         = localPos.X > 0 and 1 or -1,
                IsDirect     = isDirect or false,
                CurrentAngle = 0,   -- current lerped angle
                PrevApplied  = 0,   -- angle we wrote last frame (for delta removal)
                Dead         = false,
            })
        end

        -- Pass 2: scan Weld / Motor6D / WeldConstraint
        pcall(function()
            for _, obj in pairs(Vehicle:GetDescendants()) do
                if obj:IsA("Weld") or obj:IsA("Motor6D") then
                    local ok, p0, p1 = pcall(function() return obj.Part0, obj.Part1 end)
                    if not ok then p0 = nil; p1 = nil end
                    local wp, origC, useC1 = nil, nil, false
                    if p1 and (candidates[p1] or IsWheelName(p1.Name)) then
                        wp = p1; origC = obj.C1; useC1 = true
                    elseif p0 and (candidates[p0] or IsWheelName(p0.Name)) then
                        wp = p0; origC = obj.C0; useC1 = false
                    end
                    if wp then
                        if seenParts[wp] then
                            if obj:IsA("Weld") then
                                for i, existing in ipairs(CamberData.Wheels) do
                                    if existing.Part == wp and existing.Joint
                                       and not existing.Joint:IsA("Weld") then
                                        CamberData.Wheels[i].Joint  = obj
                                        CamberData.Wheels[i].OrigC0 = origC
                                        CamberData.Wheels[i].UseC1  = useC1
                                    end
                                end
                            end
                        else
                            AddWheel(wp, obj, origC, false, useC1)
                            candidates[wp] = nil
                        end
                    end
                elseif obj:IsA("WeldConstraint") then
                    local p0, p1
                    pcall(function() p0 = obj.Part0; p1 = obj.Part1 end)
                    local wp = nil
                    if p1 and (candidates[p1] or IsWheelName(p1.Name)) then wp = p1
                    elseif p0 and (candidates[p0] or IsWheelName(p0.Name)) then wp = p0 end
                    if wp then
                        AddWheel(wp, nil, nil, true, false)
                        candidates[wp] = nil
                    end
                end
            end
        end)

        -- Pass 3: remaining scored candidates
        local remaining = {}
        for part, score in pairs(candidates) do
            table.insert(remaining, {part=part, score=score})
        end
        table.sort(remaining, function(a,b) return a.score > b.score end)
        for _, entry in ipairs(remaining) do
            AddWheel(entry.part, nil, nil, true, false)
        end

        -- Pass 4: corner geometry fallback (guarantees all 4 corners)
        local function HasCorner(isFront, side)
            for _, w in ipairs(CamberData.Wheels) do
                if w.IsFront == isFront and w.Side == side then return true end
            end
            return false
        end

        local corners = {
            {isFront=true,  side= 1}, {isFront=true,  side=-1},
            {isFront=false, side= 1}, {isFront=false, side=-1},
        }
        for _, corner in ipairs(corners) do
            if not HasCorner(corner.isFront, corner.side) then
                local best, bestScore = nil, -math.huge
                for _, obj in pairs(Vehicle:GetDescendants()) do
                    if obj:IsA("BasePart") and not seenParts[obj] then
                        local lp   = primCF:PointToObjectSpace(obj.Position)
                        local isFr = lp.Z > 0
                        local sd   = lp.X > 0 and 1 or -1
                        if isFr == corner.isFront and sd == corner.side then
                            local n = obj.Name:lower()
                            local blocked = false
                            for _, kw in pairs(NONWHEEL_KW) do
                                if n:find(kw,1,true) then blocked=true; break end
                            end
                            if not blocked then
                                local s = math.abs(lp.X) * 2 - math.abs(lp.Y)
                                if obj:IsA("Part") and obj.Shape == Enum.PartType.Cylinder then
                                    s = s + 20
                                end
                                if s > bestScore then bestScore=s; best=obj end
                            end
                        end
                    end
                end
                if best then
                    local bj, bOrigC, bUseC1 = nil, nil, false
                    for _, obj in pairs(Vehicle:GetDescendants()) do
                        if obj:IsA("Weld") or obj:IsA("Motor6D") then
                            local ok, p0, p1 = pcall(function() return obj.Part0, obj.Part1 end)
                            if ok then
                                if p1 == best then
                                    bj=obj; bOrigC=obj.C1; bUseC1=true; break
                                elseif p0 == best then
                                    bj=obj; bOrigC=obj.C0; bUseC1=false; break
                                end
                            end
                        end
                    end
                    AddWheel(best, bj, bOrigC, bj==nil, bUseC1)
                end
            end
        end

        -- Remove stray centre part if odd count
        local count = #CamberData.Wheels
        if count > 0 and count % 2 ~= 0 then
            local worstIdx, worstAbsX = nil, math.huge
            for i, w in ipairs(CamberData.Wheels) do
                local lp = primCF:PointToObjectSpace(w.Part.Position)
                if math.abs(lp.X) < worstAbsX then
                    worstAbsX = math.abs(lp.X); worstIdx = i
                end
            end
            if worstIdx then table.remove(CamberData.Wheels, worstIdx) end
        end
    end

    local function RestoreCamber()
        for _, w in pairs(CamberData.Wheels) do
            if w.Joint and w.Joint.Parent and w.OrigC0 then
                pcall(function()
                    if w.UseC1 then w.Joint.C1 = w.OrigC0
                    else             w.Joint.C0 = w.OrigC0 end
                end)
            end
            w.CurrentAngle = 0
            w.PrevApplied  = 0
            w.Dead = false
        end
        CamberData.Enabled = false
        CamberData.Wheels  = {}
    end

    -- ============================================================
    -- VEHICLE CACHE
    -- ============================================================
    local function CacheSuspension(Vehicle)
        SuspCache.Springs        = {}
        SuspCache.OriginalValues = {}
        SuspCache.SpringCount    = 0
        for _, obj in pairs(Vehicle:GetDescendants()) do
            if obj:IsA("SpringConstraint") then
                SuspCache.OriginalValues[obj] = {
                    Stiffness  = obj.Stiffness,
                    Damping    = obj.Damping,
                    FreeLength = obj.FreeLength,
                    MinLength  = obj.MinLength,
                    MaxLength  = obj.MaxLength,
                }
                table.insert(SuspCache.Springs, obj)
                SuspCache.SpringCount = SuspCache.SpringCount + 1
            end
        end
    end

    local function CacheParts(Vehicle)
        Internal.PartsCache  = {}
        Internal.VehicleMass = 0
        for _, p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                table.insert(Internal.PartsCache, p)
                pcall(function()
                    Internal.VehicleMass = Internal.VehicleMass + p:GetMass()
                end)
            end
        end
    end

    local function SetNetworkOwnership(Vehicle)
        pcall(function()
            for _, p in pairs(Vehicle:GetDescendants()) do
                if p:IsA("BasePart") then
                    p:SetNetworkOwner(LocalPlayer)
                end
            end
        end)
    end

    local function OnVehicleEntered(Vehicle, Seat)
        if not Vehicle.PrimaryPart then Vehicle.PrimaryPart = Seat end
        SetNetworkOwnership(Vehicle)
        CacheSuspension(Vehicle)
        CacheParts(Vehicle)
        if SuspCache.SpringCount > 0 then
            local sum, count = 0, 0
            for _, orig in pairs(SuspCache.OriginalValues) do
                sum = sum + orig.FreeLength; count = count + 1
            end
            if count > 0 then
                SuspData.OrigBaseHeight = sum / count
                SuspData.CurrentHeight  = SuspData.OrigBaseHeight
            end
        end
        AB.PrevVelocity    = Vector3.new(0,0,0)
        AB.PrevSurface     = nil
        AB.InTransition    = false
        AB.LastImpactTime  = 0
        AB.VelocityHistory = {}
        local now = tick()
        if now - Internal.LastNotifTime > 2 then
            Internal.LastNotifTime = now
            Notif("Vehicle Detected",
                Vehicle.Name .. "  |  " .. SuspCache.SpringCount .. " springs"
                .. "  |  " .. (Internal.IsDriver and "Driver" or "Passenger"))
        end
    end

    local function OnVehicleLeft()
        if F.BypassBrakeEnabled and Internal.Seat then
            pcall(function()
                Internal.Seat.Throttle = 0
                Internal.Seat.Steer    = 0
            end)
        end
        if F.NoclipForce then pcall(function() F.NoclipForce:Destroy() end); F.NoclipForce = nil end
        if F.NoclipAtt   then pcall(function() F.NoclipAtt:Destroy()   end); F.NoclipAtt   = nil end
        if F.GravForce   then pcall(function() F.GravForce:Destroy()   end); F.GravForce   = nil end
        if F.GravAtt     then pcall(function() F.GravAtt:Destroy()     end); F.GravAtt     = nil end
        -- Restore camber joints when leaving
        if CamberData.Enabled then RestoreCamber() end
        Internal.Vehicle     = nil
        Internal.Seat        = nil
        Internal.PartsCache  = {}
        Internal.VehicleMass = 0
        SuspCache.Springs    = {}
        SuspCache.SpringCount = 0
        AB.VelocityHistory = {}
        AB.PrevVelocity    = Vector3.new(0,0,0)
        AB.PrevSurface     = nil
        AB.InTransition    = false
    end

    local _lastVehicleCheck = 0
    local function UpdateVehicleRef(now)
        if now - _lastVehicleCheck < 0.5 then return end
        _lastVehicleCheck = now
        local Char = LocalPlayer.Character
        if not Char then return end
        local Hum = Char:FindFirstChildWhichIsA("Humanoid")
        if not Hum then return end
        local SeatPart = Hum.SeatPart
        if SeatPart and SeatPart:IsA("VehicleSeat") then
            local Model = SeatPart:FindFirstAncestorWhichIsA("Model")
            if Model then
                Internal.IsDriver = true
                if Model ~= Internal.Vehicle then
                    Internal.Vehicle = Model
                    Internal.Seat    = SeatPart
                    OnVehicleEntered(Model, SeatPart)
                elseif SeatPart ~= Internal.Seat then
                    Internal.Seat = SeatPart
                end
            end
        elseif SeatPart and SeatPart:IsA("Seat") then
            local Model = SeatPart:FindFirstAncestorWhichIsA("Model")
            if Model then
                Internal.IsDriver = false
                if Model ~= Internal.Vehicle then
                    Internal.Vehicle = Model
                    Internal.Seat    = nil
                    OnVehicleEntered(Model, SeatPart)
                end
            end
        else
            if Internal.Vehicle then
                Internal.IsDriver = false
                OnVehicleLeft()
            end
        end
    end

    local function ForceVehicleCheck() _lastVehicleCheck = 0 end

    local function ConnectCharacter(char)
        local hum = char:WaitForChild("Humanoid", 5)
        if not hum then return end
        hum:GetPropertyChangedSignal("SeatPart"):Connect(function()
            ForceVehicleCheck()
            if not hum.SeatPart then
                if Internal.Vehicle then OnVehicleLeft() end
            end
        end)
    end

    if LocalPlayer.Character then ConnectCharacter(LocalPlayer.Character) end
    table.insert(connections, LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(1)
        ConnectCharacter(char)
    end))

    -- ============================================================
    -- CAMBER ENGINE  (Heartbeat — runs every frame before physics)
    -- ============================================================
    --
    -- Three improvements over the previous Stepped approach:
    --
    -- 1. DELTA TILT (no steering loss on Motor6D joints)
    --    Instead of always overriding from OrigC0 (neutral steering),
    --    we read the LIVE joint CFrame each frame, undo last frame's
    --    camber contribution, then apply this frame's. Steering set
    --    by the game is preserved because we only change the rotation
    --    DELTA, not the absolute value.
    --
    -- 2. DYNAMIC CAMBER (speed + lateral G)
    --    When Dynamic Mode is ON, extra camber is added on top of the
    --    base slider value proportional to vehicle speed and cornering
    --    force. Faster = more camber. Hard cornering = more camber.
    --    This gives a realistic "suspension roll → camber gain" feel.
    --
    -- 3. HEARTBEAT (matches suggestion #5)
    --    RunService.Heartbeat fires every frame. CFrame writes here
    --    are visible within the same frame, giving smoother visuals
    --    than Stepped which runs after the physics solver.
    --
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        if not CamberData.Enabled then return end
        if #CamberData.Wheels == 0 then return end
        local Vehicle = Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then return end
        local Seat = Internal.Seat

        -- ── Compute effective target angle ─────────────────────────
        -- Base angle: range expanded to ±15 for more extreme stance builds
        local baseDeg = math.clamp(CamberData.Angle, -15, 15)

        -- Add dynamic component when enabled and seated
        local dynamicAdd = 0
        if CamberData.DynamicEnabled and Seat then
            pcall(function()
                local vel      = Seat.AssemblyLinearVelocity
                local speed    = vel.Magnitude
                local primCF   = Vehicle.PrimaryPart.CFrame
                local lateralV = math.abs(primCF:VectorToObjectSpace(vel).X)

                -- Speed contribution: reaches DynamicMaxAdd * SpeedFactor at SpeedRef st/s
                local speedRatio   = math.clamp(speed   / math.max(CamberData.SpeedRef, 1), 0, 1)
                -- Lateral G contribution: reaches DynamicMaxAdd * LateralFactor at SpeedRef/3
                local lateralRatio = math.clamp(lateralV / math.max(CamberData.SpeedRef / 3, 1), 0, 1)

                dynamicAdd = CamberData.DynamicMaxAdd
                    * (speedRatio   * CamberData.SpeedFactor
                     + lateralRatio * CamberData.LateralFactor)

                -- Dynamic camber always pushes inward regardless of base sign
                dynamicAdd = -math.abs(dynamicAdd)
            end)
        end

        -- Final target clamped to ±15 (safe physics limit)
        local targetDeg = math.clamp(baseDeg + dynamicAdd, -15, 15)

        -- Frame-rate-independent smooth lerp — speed configurable by user
        local lerpAlpha = 1 - math.exp(-CamberData.LerpSpeed * dt)
        local needPrune = false

        for _, w in ipairs(CamberData.Wheels) do
            local skip = false
            if w.Dead then
                needPrune = true; skip = true
            elseif not w.Part or not w.Part.Parent then
                w.Dead = true; needPrune = true; skip = true
            elseif not w.Joint or not w.Joint.Parent then
                w.Dead = true; needPrune = true; skip = true
            elseif not w.OrigC0 then
                skip = true
            elseif not (w.Joint:IsA("Weld") or w.Joint:IsA("Motor6D")) then
                skip = true
            end

            if not skip then
                pcall(function()
                    -- Smooth lerp toward target
                    w.CurrentAngle = w.CurrentAngle
                        + (targetDeg - w.CurrentAngle) * lerpAlpha
                    if math.abs(w.CurrentAngle - targetDeg) < 0.005 then
                        w.CurrentAngle = targetDeg
                    end

                    -- At zero: snap back to exact OrigC0 (eliminates all drift)
                    if math.abs(w.CurrentAngle) < 0.005 then
                        if w.UseC1 then w.Joint.C1 = w.OrigC0
                        else             w.Joint.C0 = w.OrigC0 end
                        w.PrevApplied  = 0
                        w.CurrentAngle = 0
                        return
                    end

                    -- Drift guard: if PrevApplied has drifted far from CurrentAngle
                    -- (can happen after a vehicle update resets joints), re-anchor
                    -- PrevApplied to CurrentAngle so the delta calc stays stable.
                    if math.abs(w.PrevApplied - w.CurrentAngle) > 8 then
                        w.PrevApplied = w.CurrentAngle
                    end

                    -- ── DELTA TILT: read live joint, undo prev, apply new ───
                    --
                    -- The game may have updated C0/C1 since last frame (e.g.
                    -- Motor6D steering joints). By reading the live value and
                    -- applying only the CHANGE in camber angle (delta), we
                    -- preserve whatever the game set — steering, suspension
                    -- travel, anything — and only add our tilt on top.
                    --
                    -- prevTilt = what we applied last frame
                    -- newTilt  = what we want to apply this frame
                    -- live     = current joint state (may have steering etc.)
                    -- result   = live with prevTilt removed, newTilt added

                    local live = w.UseC1 and w.Joint.C1 or w.Joint.C0

                    local prevRad = math.rad(w.PrevApplied) * w.Side
                    local newRad  = math.rad(w.CurrentAngle) * w.Side

                    local prevTilt = CFrame.fromAxisAngle(w.CamberAxis, prevRad)
                    local newTilt  = CFrame.fromAxisAngle(w.CamberAxis, newRad)

                    -- Rebuild using live position (which is the true hub point
                    -- even after steering) and live rotation with delta applied
                    local livePos = live.Position
                    local liveRot = CFrame.fromMatrix(
                        Vector3.zero, live.RightVector, live.UpVector)

                    -- Remove previous camber, add new camber — in offset-local space
                    local newRot = liveRot * prevTilt:Inverse() * newTilt
                    local newCF  = CFrame.new(livePos) * newRot

                    if w.UseC1 then w.Joint.C1 = newCF
                    else             w.Joint.C0 = newCF end

                    w.PrevApplied = w.CurrentAngle
                end)
            end
        end

        if needPrune then
            for i = #CamberData.Wheels, 1, -1 do
                if CamberData.Wheels[i].Dead then
                    table.remove(CamberData.Wheels, i)
                end
            end
        end
    end))

    -- ============================================================
    -- SUSPENSION STEPPED LOOP
    -- ============================================================
    table.insert(connections, RunService.Stepped:Connect(function(_, dt)
        if not SuspData.Enabled then return end
        if SuspCache.SpringCount == 0 then return end
        local Vehicle = Internal.Vehicle
        local Seat    = Internal.Seat
        if not Vehicle or not Seat then return end
        if not Vehicle.PrimaryPart then return end
        pcall(function()
            local primCF   = Vehicle.PrimaryPart.CFrame
            local velocity = Seat.AssemblyLinearVelocity
            local speed    = velocity.Magnitude
            local lateralV = primCF:VectorToObjectSpace(velocity).X
            if SuspData.BounceEnabled then
                SuspData.BouncePhase = SuspData.BouncePhase + dt * SuspData.BounceFreq * math.pi * 2
            end
            local base = SuspData.OrigBaseHeight
            local heightTarget
            if SuspData.HydroEnabled then
                heightTarget = base * SuspData.HydroPressure + SuspData.Height + SuspData.Preload
            else
                heightTarget = base + SuspData.Height + SuspData.Preload
            end
            local lerpRate = math.clamp(SuspData.HydroSpeed * 60 * dt, 0, 1)
            SuspData.CurrentHeight = SuspData.CurrentHeight + (heightTarget - SuspData.CurrentHeight) * lerpRate
            for i = 1, #SuspCache.Springs do
                local spring = SuspCache.Springs[i]
                if spring and spring.Parent then
                    pcall(function()
                        local orig = SuspCache.OriginalValues[spring]
                        if not orig then return end
                        local isFront = false
                        local att = spring.Attachment0 or spring.Attachment1
                        if att and att.Parent then
                            isFront = primCF:PointToObjectSpace(att.WorldPosition).Z > 0
                        end
                        local stiff = isFront and SuspData.FrontStiff or SuspData.RearStiff
                        if SuspData.ARB then
                            local turning = UserInputService:IsKeyDown(Enum.KeyCode.A)
                                         or UserInputService:IsKeyDown(Enum.KeyCode.D)
                            if turning then
                                stiff = stiff + SuspData.ARB_Str + math.abs(lateralV) * SuspData.ARB_Str * 0.004
                            end
                        end
                        if SuspData.DriftMode then
                            stiff = isFront and (stiff * 1.25) or (stiff * 0.5)
                        end
                        spring.Stiffness = math.clamp(math.abs(stiff), 100, 60000)
                        spring.Damping   = math.clamp(math.abs(SuspData.Damping), 10, 5000)
                        local bounceOff  = SuspData.BounceEnabled and (math.sin(SuspData.BouncePhase) * SuspData.BounceAmplitude) or 0
                        local squatOff   = 0
                        if speed > 5 then
                            squatOff = math.clamp(-speed * 0.002, -0.4, 0)
                            if not isFront then squatOff = squatOff * 1.6 end
                        end
                        local finalLen = math.clamp(
                            SuspData.CurrentHeight + bounceOff + squatOff,
                            orig.MinLength * 0.5, orig.MaxLength * 1.5)
                        spring.FreeLength = finalLen
                    end)
                end
            end
        end)
    end))

    -- ============================================================
    -- HEARTBEAT
    -- ============================================================
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        local now = tick()
        pcall(UpdateVehicleRef, now)
        local Seat    = Internal.Seat
        local Vehicle = Internal.Vehicle
        if not Vehicle then return end

        repeat
            if not Seat then break end

            if AB.Enabled then
                pcall(function()
                    local curVel    = Seat.AssemblyLinearVelocity
                    local prevVel   = AB.PrevVelocity
                    local velChange = (curVel - prevVel).Magnitude
                    if velChange > AB.ImpactThreshold then AB.LastImpactTime = now end
                    table.insert(AB.VelocityHistory, curVel)
                    if #AB.VelocityHistory > AB.SmoothingFrames then table.remove(AB.VelocityHistory, 1) end
                    if velChange > AB.MaxVelocityChange and prevVel.Magnitude > 1e-4 then
                        Seat.AssemblyLinearVelocity = prevVel + SafeUnit(curVel - prevVel) * AB.MaxVelocityChange
                    end
                    if AB.SurfaceSmoothing and (now - AB.LastRaycastTime) >= 0.05 then
                        AB.LastRaycastTime = now
                        pcall(function()
                            local params = RaycastParams.new()
                            params.FilterType = Enum.RaycastFilterType.Exclude
                            params.FilterDescendantsInstances = { Vehicle }
                            local result = Workspace:Raycast(Seat.Position, Vector3.new(0,-10,0), params)
                            if result then
                                local curSurf  = { Instance = result.Instance, Height = result.Position.Y }
                                local prevSurf = AB.PrevSurface
                                if prevSurf then
                                    local hDiff = math.abs(curSurf.Height - prevSurf.Height)
                                    if curSurf.Instance ~= prevSurf.Instance or hDiff > 0.5 then
                                        AB.InTransition = true; AB.TransitionStart = now
                                        local v = Seat.AssemblyLinearVelocity
                                        Seat.AssemblyLinearVelocity  = Vector3.new(v.X, v.Y * AB.TransitionDampening, v.Z)
                                        Seat.AssemblyAngularVelocity = Seat.AssemblyAngularVelocity * (AB.TransitionDampening * 0.4)
                                    end
                                end
                                AB.PrevSurface = curSurf
                            end
                        end)
                    end
                    if AB.InTransition then
                        if now - AB.TransitionStart < 0.2 then
                            Seat.AssemblyLinearVelocity = Seat.AssemblyLinearVelocity * 0.96
                        else AB.InTransition = false end
                    end
                    local tsi = now - AB.LastImpactTime
                    if tsi < AB.StabilizationTime then
                        local progress = tsi / AB.StabilizationTime
                        Seat.AssemblyLinearVelocity  = Seat.AssemblyLinearVelocity  * (AB.VelocityDampening + (1-AB.VelocityDampening) * progress)
                        Seat.AssemblyAngularVelocity = Seat.AssemblyAngularVelocity * (AB.AngularDampening  + (1-AB.AngularDampening)  * progress)
                        if Vehicle.PrimaryPart then
                            local up   = Vehicle.PrimaryPart.CFrame.UpVector
                            local tUp  = Vector3.new(0,1,0)
                            local tilt = math.acos(math.clamp(up:Dot(tUp),-1,1))
                            if tilt > math.rad(8) then
                                local cross = up:Cross(tUp)
                                if cross.Magnitude > 1e-4 then
                                    pcall(function() Seat:ApplyAngularImpulse(cross.Unit * (tilt * 28 * (1-progress))) end)
                                end
                            end
                        end
                    end
                    AB.PrevVelocity = Seat.AssemblyLinearVelocity
                end)
            end

            if F.AutoSpeed and Internal.IsDriver then
                pcall(function()
                    local vel = Seat.AssemblyLinearVelocity
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        local newV = vel + Seat.CFrame.LookVector * (F.AutoAccel * dt * 60)
                        -- Only cap if MaxSpeed is a finite number (math.huge = unlimited)
                        if F.MaxSpeed ~= math.huge and F.MaxSpeed > 0 then
                            local hspd = Vector3.new(newV.X, 0, newV.Z)
                            if hspd.Magnitude > F.MaxSpeed then
                                local c = hspd.Unit * F.MaxSpeed
                                newV = Vector3.new(c.X, newV.Y, c.Z)
                            end
                        end
                        newV = Vector3.new(newV.X, math.clamp(newV.Y, -50, 50), newV.Z)
                        Seat.AssemblyLinearVelocity = newV
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        local bf = math.clamp(1 - F.AutoBrake * 0.1, 0, 1)
                        Seat.AssemblyLinearVelocity = vel * Vector3.new(bf, 0.98, bf)
                    end
                end)
            end

            if F.Traction and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local cf = Vehicle.PrimaryPart.CFrame
                    local latVel = cf:VectorToObjectSpace(Seat.AssemblyLinearVelocity).X
                    if math.abs(latVel) > 0.5 then
                        Seat:ApplyImpulse(cf.RightVector * -latVel * (1 - F.TractionGrip) * 50)
                    end
                end)
            end

            if F.BrakeOverride and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local pp = Vehicle.PrimaryPart
                    local cf = pp.CFrame
                    local blend = math.clamp(dt * 20, 0, 1)
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        local cur = pp.AssemblyLinearVelocity
                        local des = cf.LookVector * F.BrakeForce
                        pp.AssemblyLinearVelocity = Vector3.new(cur.X+(des.X-cur.X)*blend, cur.Y, cur.Z+(des.Z-cur.Z)*blend)
                        pcall(function() Seat.Throttle = 1 end)
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        local cur = pp.AssemblyLinearVelocity
                        local des = -cf.LookVector * (F.BrakeForce * 0.55)
                        pp.AssemblyLinearVelocity = Vector3.new(cur.X+(des.X-cur.X)*blend, cur.Y, cur.Z+(des.Z-cur.Z)*blend)
                        pcall(function() Seat.Throttle = -1 end)
                    else
                        local bf = math.pow(0.01, dt)
                        local cur = pp.AssemblyLinearVelocity
                        pp.AssemblyLinearVelocity = Vector3.new(cur.X*bf, cur.Y, cur.Z*bf)
                        pcall(function() Seat.Throttle = 0 end)
                    end
                    local turnInput = 0
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then turnInput = -1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then turnInput = 1 end
                    if turnInput ~= 0 then
                        if math.deg(math.abs(pp.AssemblyAngularVelocity.Y)) < 100 then
                            pp:ApplyAngularImpulse(cf.UpVector * (turnInput * 12 * dt * 60))
                        end
                        pcall(function() Seat.Steer = -turnInput end)
                    else
                        local av = pp.AssemblyAngularVelocity
                        pp.AssemblyAngularVelocity = Vector3.new(av.X, av.Y * math.pow(0.001,dt), av.Z)
                        pcall(function() Seat.Steer = 0 end)
                    end
                end)
            end

            if F.BypassBrakeEnabled and Internal.IsDriver then
                pcall(function()
                    local throttle, steer = 0, 0
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then throttle = 1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then throttle = -1 end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then steer = 1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then steer = -1 end
                    Seat.Throttle = throttle * F.BypassThrottlePower
                    Seat.Steer    = steer    * F.BypassSteerPower
                    F.BypassThrottle = Seat.Throttle
                    F.BypassSteer    = Seat.Steer
                end)
            end

            if F.TireEnabled and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local cf       = Vehicle.PrimaryPart.CFrame
                    local vel      = Seat.AssemblyLinearVelocity
                    local angVel   = Seat.AssemblyAngularVelocity
                    local speed    = vel.Magnitude
                    local localVel = cf:VectorToObjectSpace(vel)
                    local latVel   = localVel.X
                    local yawRate  = angVel.Y
                    if F.TurnBoostEnabled then
                        local turnInput = 0
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then turnInput = 1
                        elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then turnInput = -1 end
                        if turnInput ~= 0 then
                            if math.deg(math.abs(yawRate)) < F.TurnBoostMaxRate then
                                local speedFactor = math.clamp(speed/30, 0.15, 1.0)
                                pcall(function() Seat:ApplyAngularImpulse(cf.UpVector * (turnInput * F.TurnBoostPower * speedFactor * dt * 60)) end)
                            end
                        else
                            Seat.AssemblyAngularVelocity = Vector3.new(angVel.X, angVel.Y * F.TurnBoostSmoothing, angVel.Z)
                        end
                    end
                    if F.TireGripEnabled and math.abs(latVel) > 0.3 then
                        local effectiveGrip = F.TireGrip
                        if F.WheelspinEnabled and speed > F.WheelspinThreshold then
                            local excess = math.clamp((speed - F.WheelspinThreshold)/40, 0, 1)
                            effectiveGrip = effectiveGrip * (1 - excess * (1 - F.WheelspinStrength))
                        end
                        local lateralForce = -latVel * effectiveGrip * math.clamp(speed * 0.08, 0.5, 8.0)
                        pcall(function() Seat:ApplyImpulse(cf.RightVector * lateralForce) end)
                    end
                    if F.BurnoutActive and Vehicle.PrimaryPart then
                        if math.abs(localVel.Z) < 5 then
                            Seat.AssemblyLinearVelocity = Vector3.new(vel.X*0.85, vel.Y, vel.Z*0.85)
                        end
                        Seat.AssemblyAngularVelocity = Vector3.new(angVel.X, angVel.Y + (math.random()-0.5)*0.4, angVel.Z)
                    end
                    F.TireStats.AngularSpeed = math.floor(math.deg(math.abs(yawRate)))
                    F.TireStats.LatForce     = math.floor(math.abs(latVel) * 10) / 10
                end)
            end
        until true

        if F.AnticheatEnabled and Internal.Vehicle then
            if now - F.AC_LastRun >= F.AC_Interval then
                F.AC_LastRun = now
                pcall(function()
                    local Vehicle = Internal.Vehicle
                    if F.AC_NetworkOwner then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent then pcall(function() p:SetNetworkOwner(LocalPlayer) end) end
                        end
                    end
                    if F.AC_UnanchorAll and not F.Freeze then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent and p.Anchored then pcall(function() p.Anchored = false end) end
                        end
                    end
                    if F.AC_ClearForces then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent then
                                for _, child in pairs(p:GetChildren()) do
                                    if (child:IsA("BodyVelocity") or child:IsA("BodyAngularVelocity")
