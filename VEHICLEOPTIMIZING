    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        if not F.FlightEnabled then
            if F._FlyVel.Magnitude > 0.1 then
                F._FlyVel = F._FlyVel * math.max(0, 1 - dt * 12)
            else
                F._FlyVel = Vector3.new(0, 0, 0)
            end
            return
        end
        pcall(function()
            local Vehicle = Internal.Vehicle
            local Seat    = Internal.Seat
            if not Vehicle or not Seat then return end
            if not Vehicle.PrimaryPart then return end
            local Char = LocalPlayer.Character
            if not Char then return end
            if Char.Parent ~= Vehicle then
                F.DefaultCharParent = F.DefaultCharParent or Char.Parent
                Char.Parent = Vehicle
            end
            local cam      = Workspace.CurrentCamera.CFrame
            local camYaw   = CFrame.new(cam.Position) * CFrame.Angles(0, math.atan2(-cam.LookVector.X, -cam.LookVector.Z), 0)
            local camFwd   = camYaw.LookVector
            local camRight = camYaw.RightVector
            local worldUp  = Vector3.new(0,1,0)
            local fwd, right, up = 0, 0, 0
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then fwd   =  1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then fwd   = -1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then right = -1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then right =  1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then up    =  1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then up    = -1 end
            local hasInput = (fwd ~= 0 or right ~= 0 or up ~= 0)
            local desiredVel
            if hasInput then
                local horizontal = camFwd * fwd + camRight * right
                if horizontal.Magnitude > 0.01 then
                    horizontal = horizontal.Unit * F.FlightSpeed * math.min(math.abs(fwd) + math.abs(right), 1)
                else horizontal = Vector3.new(0,0,0) end
                desiredVel = horizontal + worldUp * (up * F.FlightUpSpeed)
            else
                desiredVel = Vector3.new(0,0,0)
            end
            if F.FlightHoverHeight > 0 then
                local rayParams = RaycastParams.new()
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                rayParams.FilterDescendantsInstances = { Vehicle }
                local origin = Vehicle.PrimaryPart.Position
                local result = Workspace:Raycast(origin, Vector3.new(0,-200,0), rayParams)
                if result then
                    local diff = F.FlightHoverHeight - (origin.Y - result.Position.Y)
                    desiredVel = Vector3.new(desiredVel.X, desiredVel.Y + math.clamp(diff*3,-15,15), desiredVel.Z)
                end
            end
            local accel = hasInput and F.FlightAccel or F.FlightBrakeStrength
            local blend = math.clamp(accel * dt, 0, 1)
            F._FlyVel = F._FlyVel + (desiredVel - F._FlyVel) * blend
            local maxSpd = F.FlightSpeed * 2.5
            if F._FlyVel.Magnitude > maxSpd then F._FlyVel = F._FlyVel.Unit * maxSpd end
            Seat.AssemblyLinearVelocity  = F._FlyVel
            Seat.AssemblyAngularVelocity = Vector3.new(0,0,0)
            local targetYaw
            if F.FlightMouseSteer then
                targetYaw = math.atan2(-cam.LookVector.X, -cam.LookVector.Z)
            else
                if math.abs(fwd) + math.abs(right) > 0 then
                    local moveDir = camFwd * fwd + camRight * right
                    if moveDir.Magnitude > 0.01 then targetYaw = math.atan2(-moveDir.X, -moveDir.Z)
                    else targetYaw = F._FlyYaw end
                else targetYaw = F._FlyYaw end
            end
            local yawDiff = targetYaw - F._FlyYaw
            if yawDiff >  math.pi then yawDiff = yawDiff - 2*math.pi end
            if yawDiff < -math.pi then yawDiff = yawDiff + 2*math.pi end
            F._FlyYaw = F._FlyYaw + yawDiff * math.clamp(dt*7, 0, 1)
            local speedRatio = math.clamp(F._FlyVel.Magnitude / F.FlightSpeed, 0, 1)
            local pitchAngle = -math.rad(8) * speedRatio * (fwd > 0 and 1 or 0)
            F._FlyPitch = F._FlyPitch + (pitchAngle - F._FlyPitch) * math.clamp(dt*6,0,1)
            local rollAngle = math.rad(18) * right * F.FlightRollFactor * math.clamp(F._FlyVel.Magnitude/20,0,1)
            Vehicle:SetPrimaryPartCFrame(
                CFrame.new(Vehicle.PrimaryPart.Position)
                * CFrame.Angles(0, F._FlyYaw, 0)
                * CFrame.Angles(F._FlyPitch, 0, -rollAngle)
            )
        end)
    end))

