    -- Safe Vector3 unit (avoids NaN on zero vector)
    local function SafeUnit(v)
        return v.Magnitude > 1e-5 and v.Unit or Vector3.new(0,0,0)
    end

    -- ==========================================================
    -- VEHICLE CACHE ENGINE
    -- ==========================================================
    local function CacheSuspension(Vehicle)
        SuspCache.Springs        = {}
        SuspCache.OriginalValues = {}
        SuspCache.SpringCount    = 0

        for _, obj in pairs(Vehicle:GetDescendants()) do
            if obj:IsA("SpringConstraint") then
                SuspCache.OriginalValues[obj] = {
                    Stiffness  = obj.Stiffness,
                    Damping    = obj.Damping,
                    FreeLength = obj.FreeLength,
                    MinLength  = obj.MinLength,
                    MaxLength  = obj.MaxLength,
                }
                table.insert(SuspCache.Springs, obj)
                SuspCache.SpringCount = SuspCache.SpringCount + 1
            end
        end
        print(("[VehicleVoxels] Cached %d springs for: %s"):format(
            SuspCache.SpringCount, Vehicle.Name))
    end

    local function CacheParts(Vehicle)
        Internal.PartsCache  = {}
        Internal.VehicleMass = 0

        for _, p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                table.insert(Internal.PartsCache, p)
                pcall(function()
                    Internal.VehicleMass = Internal.VehicleMass + p:GetMass()
                end)
                -- NOTE: We do NOT touch CustomPhysicalProperties here.
                -- Changing friction/elasticity on wheels causes the vehicle
                -- to glitch and slide. The game's own values are correct.
            end
        end
    end

    local function SetNetworkOwnership(Vehicle)
        pcall(function()
            for _, p in pairs(Vehicle:GetDescendants()) do
                if p:IsA("BasePart") then
                    p:SetNetworkOwner(LocalPlayer)
                end
            end
        end)
    end

    -- Called once when we detect a new vehicle
    local function OnVehicleEntered(Vehicle, Seat)
        if not Vehicle.PrimaryPart then Vehicle.PrimaryPart = Seat end

        SetNetworkOwnership(Vehicle)
        CacheSuspension(Vehicle)
        CacheParts(Vehicle)

        -- Reset suspension base height from this vehicle's actual spring values
        -- so the engine never uses a stale value from the previous vehicle
        if SuspCache.SpringCount > 0 then
            local sum, count = 0, 0
            for _, orig in pairs(SuspCache.OriginalValues) do
                sum   = sum   + orig.FreeLength
                count = count + 1
            end
            if count > 0 then
                SuspData.OrigBaseHeight = sum / count
                SuspData.CurrentHeight  = SuspData.OrigBaseHeight
            end
        end

        -- Reset anti-bounce state
        AB.PrevVelocity    = Vector3.new(0,0,0)
        AB.PrevSurface     = nil
        AB.InTransition    = false
        AB.LastImpactTime  = 0
        AB.VelocityHistory = {}

        -- Notify (throttled so it doesn't spam if seat changes quickly)
        local now = tick()
        if now - Internal.LastNotifTime > 2 then
            Internal.LastNotifTime = now
            local mass = math.floor(Internal.VehicleMass)
            local driverStr = Internal.IsDriver and "Driver" or "Passenger"
            Notif("Vehicle Detected",
                Vehicle.Name
                .. "  |  " .. SuspCache.SpringCount .. " springs"
                .. "  |  " .. driverStr)
        end
    end

    -- Called once when we leave / lose a vehicle
    local function OnVehicleLeft()
        -- Restore seat throttle/steer to neutral if bypass was active
        if F.BypassBrakeEnabled and Internal.Seat then
            pcall(function()
                Internal.Seat.Throttle = 0
                Internal.Seat.Steer    = 0
            end)
        end

        -- Clean up noclip force
        if F.NoclipForce then pcall(function() F.NoclipForce:Destroy() end); F.NoclipForce = nil end
        if F.NoclipAtt   then pcall(function() F.NoclipAtt:Destroy()   end); F.NoclipAtt   = nil end
        -- Clean up gravity force
        if F.GravForce   then pcall(function() F.GravForce:Destroy()   end); F.GravForce   = nil end
        if F.GravAtt     then pcall(function() F.GravAtt:Destroy()     end); F.GravAtt     = nil end

        Internal.Vehicle     = nil
        Internal.Seat        = nil
        Internal.PartsCache  = {}
        Internal.VehicleMass = 0
        SuspCache.Springs    = {}
        SuspCache.SpringCount = 0

        AB.VelocityHistory = {}
        AB.PrevVelocity    = Vector3.new(0,0,0)
        AB.PrevSurface     = nil
        AB.InTransition    = false
    end

    -- Vehicle ref update — throttled to every 0.5 s
    -- NOTE: Set _lastVehicleCheck = 0 to force an immediate check
    local _lastVehicleCheck = 0
    local function UpdateVehicleRef(now)
        if now - _lastVehicleCheck < 0.5 then return end
        _lastVehicleCheck = now

        local Char = LocalPlayer.Character
        if not Char then return end
        local Hum = Char:FindFirstChildWhichIsA("Humanoid")
        if not Hum then return end
        local SeatPart = Hum.SeatPart

        -- ── Only treat a VehicleSeat as the "driver" seat ─────────
        -- If the player is a passenger (Seat, not VehicleSeat) we
        -- still cache the vehicle model so suspension/anti-bounce
        -- work, but we set IsDriver = false so the tire system and
        -- other impulse-based systems don't apply angular/linear
        -- impulses via the wrong part.
        if SeatPart and SeatPart:IsA("VehicleSeat") then
            local Model = SeatPart:FindFirstAncestorWhichIsA("Model")
            if Model then
                Internal.IsDriver = true
                if Model ~= Internal.Vehicle then
                    Internal.Vehicle = Model
                    Internal.Seat    = SeatPart
                    OnVehicleEntered(Model, SeatPart)
                elseif SeatPart ~= Internal.Seat then
                    Internal.Seat = SeatPart
                end
            end
        elseif SeatPart and SeatPart:IsA("Seat") then
            -- Passenger seat — find the parent model but mark as non-driver
            local Model = SeatPart:FindFirstAncestorWhichIsA("Model")
            if Model then
                Internal.IsDriver = false
                if Model ~= Internal.Vehicle then
                    -- Cache the vehicle for suspension/anti-bounce only
                    Internal.Vehicle = Model
                    Internal.Seat    = nil  -- no driver seat reference
                    OnVehicleEntered(Model, SeatPart)
                end
            end
        else
            if Internal.Vehicle then
                Internal.IsDriver = false
                OnVehicleLeft()
            end
        end
    end

    -- Force an immediate vehicle check (no 0.5s wait)
    local function ForceVehicleCheck()
        _lastVehicleCheck = 0
    end

    -- Re-cache when character sits/unsits, or respawns
    local function ConnectCharacter(char)
        local hum = char:WaitForChild("Humanoid", 5)
        if not hum then return end

        -- Fire immediately on every SeatPart change (sit AND unsit)
        hum:GetPropertyChangedSignal("SeatPart"):Connect(function()
            -- Force the next Heartbeat tick to re-evaluate vehicle
            ForceVehicleCheck()
            if not hum.SeatPart then
                if Internal.Vehicle then OnVehicleLeft() end
            end
        end)
    end

    if LocalPlayer.Character then ConnectCharacter(LocalPlayer.Character) end
    table.insert(connections, LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(1)
        ConnectCharacter(char)
    end))

    -- ==========================================================
    -- SUSPENSION ENGINE  (Stepped — physics-safe frame)
    -- Only runs when user explicitly enables it via the UI toggle.
    -- When disabled, vehicle springs are completely untouched.
    -- ==========================================================
    table.insert(connections, RunService.Stepped:Connect(function(_, dt)
        -- MASTER GATE: do nothing unless user turned suspension on
        if not SuspData.Enabled then return end
        if SuspCache.SpringCount == 0 then return end

        local Vehicle = Internal.Vehicle
        local Seat    = Internal.Seat
        if not Vehicle or not Seat then return end
        if not Vehicle.PrimaryPart then return end

        pcall(function()
            local primCF   = Vehicle.PrimaryPart.CFrame
            local velocity = Seat.AssemblyLinearVelocity
            local speed    = velocity.Magnitude
            local lateralV = primCF:VectorToObjectSpace(velocity).X

            -- Bounce phase advance
            if SuspData.BounceEnabled then
                SuspData.BouncePhase = SuspData.BouncePhase
                    + dt * SuspData.BounceFreq * math.pi * 2
            end

            -- ── Height target — always relative to vehicle's real original height ──
            -- OrigBaseHeight was set from the actual cached spring FreeLength averages
            -- when the user toggled suspension on. Height/Preload are OFFSETS from that.
            local base = SuspData.OrigBaseHeight  -- e.g. 1.8 for a sports car, 2.5 for a truck
            local heightTarget
            if SuspData.HydroEnabled then
                -- Hydraulic pressure scales the base: 1.0 = stock, 0.5 = half, 2.0 = double
                heightTarget = base * SuspData.HydroPressure
                             + SuspData.Height + SuspData.Preload
            else
                heightTarget = base + SuspData.Height + SuspData.Preload
            end

            -- Smooth lerp toward target (dt-scaled so framerate independent)
            local lerpRate = math.clamp(SuspData.HydroSpeed * 60 * dt, 0, 1)
            SuspData.CurrentHeight = SuspData.CurrentHeight
                + (heightTarget - SuspData.CurrentHeight) * lerpRate

            for i = 1, #SuspCache.Springs do
                local spring = SuspCache.Springs[i]
                if spring and spring.Parent then
                    pcall(function()
                        local orig = SuspCache.OriginalValues[spring]
                        if not orig then return end  -- safety: no original cached, skip

                        -- Front / rear via attachment world position
                        local isFront = false
                        local att = spring.Attachment0 or spring.Attachment1
                        if att and att.Parent then
                            isFront = primCF:PointToObjectSpace(att.WorldPosition).Z > 0
                        end

                        -- Stiffness — only override if user changed sliders
                        local stiff = isFront and SuspData.FrontStiff or SuspData.RearStiff
                        if SuspData.ARB then
                            local turning = UserInputService:IsKeyDown(Enum.KeyCode.A)
                                         or UserInputService:IsKeyDown(Enum.KeyCode.D)
                            if turning then
                                stiff = stiff + SuspData.ARB_Str
                                      + math.abs(lateralV) * SuspData.ARB_Str * 0.004
                            end
                        end
                        if SuspData.DriftMode then
                            stiff = isFront and (stiff * 1.25) or (stiff * 0.5)
                        end

                        spring.Stiffness = math.clamp(math.abs(stiff), 100, 60000)
                        spring.Damping   = math.clamp(math.abs(SuspData.Damping), 10, 5000)

                        -- Free length: combine current height + optional layers
                        local bounceOff = SuspData.BounceEnabled
                            and (math.sin(SuspData.BouncePhase) * SuspData.BounceAmplitude)
                            or 0

                        -- Speed-based squat: rear dips under acceleration
                        local squatOff = 0
                        if speed > 5 then
                            squatOff = math.clamp(-speed * 0.002, -0.4, 0)
                            if not isFront then squatOff = squatOff * 1.6 end
                        end

                        -- Final free length clamped to each spring's OWN original limits
                        -- (not hardcoded) so we never push them beyond their design range
                        local finalLen = math.clamp(
                            SuspData.CurrentHeight + bounceOff + squatOff,
                            orig.MinLength * 0.5,   -- allow going half as low as original min
                            orig.MaxLength * 1.5    -- allow going 50% higher than original max
                        )
                        spring.FreeLength = finalLen
                        -- Do NOT override MinLength/MaxLength — let the engine use its own limits
                    end)
                end
            end
        end)
    end))

    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        local now = tick()

        -- Vehicle ref update (throttled inside, but forced on seat change)
        pcall(UpdateVehicleRef, now)

        local Seat    = Internal.Seat     -- only non-nil when IsDriver = true
        local Vehicle = Internal.Vehicle  -- non-nil for both driver and passenger

        -- Nothing to do if we're not in any vehicle at all
        if not Vehicle then return end

        -- ── Seat-dependent systems (skip entirely if not driver) ──
        -- Wrapped in do/end so we can break out early without goto
        -- (goto is not supported by all executors)
        repeat
            if not Seat then break end  -- passenger or not seated — skip all below

            -- ── Anti-bounce ──────────────────────────────────────
            if AB.Enabled then
                pcall(function()
                    local curVel    = Seat.AssemblyLinearVelocity
                    local prevVel   = AB.PrevVelocity
                    local velChange = (curVel - prevVel).Magnitude

                    -- Impact detection
                    if velChange > AB.ImpactThreshold then
                        AB.LastImpactTime = now
                    end

                    -- Velocity history ring buffer
                    table.insert(AB.VelocityHistory, curVel)
                    if #AB.VelocityHistory > AB.SmoothingFrames then
                        table.remove(AB.VelocityHistory, 1)
                    end

                    -- Clamp sudden velocity spike
                    if velChange > AB.MaxVelocityChange and prevVel.Magnitude > 1e-4 then
                        local clamped = prevVel + SafeUnit(curVel - prevVel) * AB.MaxVelocityChange
                        Seat.AssemblyLinearVelocity = clamped
                    end

                    -- Surface transition (raycast throttled to 20 Hz)
                    if AB.SurfaceSmoothing and (now - AB.LastRaycastTime) >= 0.05 then
                        AB.LastRaycastTime = now
                        pcall(function()
                            local params = RaycastParams.new()
                            params.FilterType = Enum.RaycastFilterType.Exclude
                            params.FilterDescendantsInstances = { Vehicle }
                            local result = Workspace:Raycast(
                                Seat.Position, Vector3.new(0,-10,0), params)
                            if result then
                                local curSurf  = { Instance = result.Instance, Height = result.Position.Y }
                                local prevSurf = AB.PrevSurface
                                if prevSurf then
                                    local hDiff       = math.abs(curSurf.Height - prevSurf.Height)
                                    local instChanged = curSurf.Instance ~= prevSurf.Instance
                                    if instChanged or hDiff > 0.5 then
                                        AB.InTransition    = true
                                        AB.TransitionStart = now
                                        local v = Seat.AssemblyLinearVelocity
                                        Seat.AssemblyLinearVelocity  =
                                            Vector3.new(v.X, v.Y * AB.TransitionDampening, v.Z)
                                        Seat.AssemblyAngularVelocity =
                                            Seat.AssemblyAngularVelocity * (AB.TransitionDampening * 0.4)
                                    end
                                end
                                AB.PrevSurface = curSurf
                            end
                        end)
                    end

                    -- Sustain transition dampening for 0.2 s
                    if AB.InTransition then
                        if now - AB.TransitionStart < 0.2 then
                            Seat.AssemblyLinearVelocity = Seat.AssemblyLinearVelocity * 0.96
                        else
                            AB.InTransition = false
                        end
                    end

                    -- Post-impact stabilization + upright correction
                    local tsi = now - AB.LastImpactTime
                    if tsi < AB.StabilizationTime then
                        local progress = tsi / AB.StabilizationTime
                        local vd = AB.VelocityDampening
                        local ad = AB.AngularDampening
                        Seat.AssemblyLinearVelocity  = Seat.AssemblyLinearVelocity
                            * (vd + (1-vd) * progress)
                        Seat.AssemblyAngularVelocity = Seat.AssemblyAngularVelocity
                            * (ad + (1-ad) * progress)

                        if Vehicle.PrimaryPart then
                            local up    = Vehicle.PrimaryPart.CFrame.UpVector
                            local tUp   = Vector3.new(0,1,0)
                            local dot   = math.clamp(up:Dot(tUp), -1, 1)
                            local tilt  = math.acos(dot)
                            if tilt > math.rad(8) then
                                local cross = up:Cross(tUp)
                                if cross.Magnitude > 1e-4 then
                                    local strength = 1 - progress
                                    pcall(function()
                                        Seat:ApplyAngularImpulse(
                                            cross.Unit * (tilt * 28 * strength))
                                    end)
                                end
                            end
                        end
                    end

                    AB.PrevVelocity = Seat.AssemblyLinearVelocity
                end)
            end

            -- ── Auto Speed ───────────────────────────────────────
            if F.AutoSpeed and Internal.IsDriver then
                pcall(function()
                    local vel = Seat.AssemblyLinearVelocity
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        local newV = vel + Seat.CFrame.LookVector * (F.AutoAccel * dt * 60)
                        local hspd = Vector3.new(newV.X, 0, newV.Z)
                        if hspd.Magnitude > F.MaxSpeed then
                            local c = hspd.Unit * F.MaxSpeed
                            newV = Vector3.new(c.X, newV.Y, c.Z)
                        end
                        newV = Vector3.new(newV.X, math.clamp(newV.Y,-50,50), newV.Z)
                        Seat.AssemblyLinearVelocity = newV
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        local bf = math.clamp(1 - F.AutoBrake * 0.1, 0, 1)
                        Seat.AssemblyLinearVelocity = vel * Vector3.new(bf, 0.98, bf)
                    end
                end)
            end

            -- ── Traction Control ─────────────────────────────────
            if F.Traction and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local cf     = Vehicle.PrimaryPart.CFrame
                    local latVel = cf:VectorToObjectSpace(Seat.AssemblyLinearVelocity).X
                    if math.abs(latVel) > 0.5 then
                        Seat:ApplyImpulse(cf.RightVector * -latVel * (1 - F.TractionGrip) * 50)
                    end
                end)
            end

            -- ── Brake Override ───────────────────────────────────
            -- Drives the vehicle via Vehicle.PrimaryPart (the physics
            -- assembly root), NOT Seat. Writing to the Seat part alone
            -- has no effect in most games because the Seat is a weld
            -- child — PrimaryPart owns the assembly velocity.
            if F.BrakeOverride and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local pp  = Vehicle.PrimaryPart
                    local cf  = pp.CFrame
                    local fwd = cf.LookVector
                    local spd = F.BrakeForce

                    -- Blend factor: reaches target speed in ~0.25s at 60fps
                    local blend = math.clamp(dt * 20, 0, 1)

                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        local cur = pp.AssemblyLinearVelocity
                        local des = fwd * spd
                        pp.AssemblyLinearVelocity = Vector3.new(
                            cur.X + (des.X - cur.X) * blend,
                            cur.Y,
                            cur.Z + (des.Z - cur.Z) * blend
                        )
                        -- Also force seat throttle so native VehicleSeat physics
                        -- doesn't fight us
                        pcall(function() Seat.Throttle = 1 end)

                    elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        local cur = pp.AssemblyLinearVelocity
                        local des = -fwd * (spd * 0.55)
                        pp.AssemblyLinearVelocity = Vector3.new(
                            cur.X + (des.X - cur.X) * blend,
                            cur.Y,
                            cur.Z + (des.Z - cur.Z) * blend
                        )
                        pcall(function() Seat.Throttle = -1 end)

                    else
                        -- Coast: exponential decay scaled by dt
                        local bleedFactor = math.pow(0.01, dt)
                        local cur = pp.AssemblyLinearVelocity
                        pp.AssemblyLinearVelocity = Vector3.new(
                            cur.X * bleedFactor, cur.Y, cur.Z * bleedFactor)
                        pcall(function() Seat.Throttle = 0 end)
                    end

                    -- Turning via angular impulse on PrimaryPart
                    local turnInput = 0
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                        turnInput = -1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then
                        turnInput =  1
                    end
                    if turnInput ~= 0 then
                        local yawNow = math.abs(pp.AssemblyAngularVelocity.Y)
                        if math.deg(yawNow) < 100 then
                            pp:ApplyAngularImpulse(
                                cf.UpVector * (turnInput * 12 * dt * 60))
                        end
                        pcall(function() Seat.Steer = -turnInput end)
                    else
                        local yawBleed = math.pow(0.001, dt)
                        local av = pp.AssemblyAngularVelocity
                        pp.AssemblyAngularVelocity =
                            Vector3.new(av.X, av.Y * yawBleed, av.Z)
                        pcall(function() Seat.Steer = 0 end)
                    end
                end)
            end

            -- ── Bypass Brake ──────────────────────────────────────
            if F.BypassBrakeEnabled and Internal.IsDriver then
                pcall(function()
                    local throttle = 0
                    local steer    = 0
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        throttle =  1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        throttle = -1
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                        steer =  1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then
                        steer = -1
                    end
                    Seat.Throttle = throttle * F.BypassThrottlePower
                    Seat.Steer    = steer    * F.BypassSteerPower
                    F.BypassThrottle = Seat.Throttle
                    F.BypassSteer    = Seat.Steer
                end)
            end

            -- ── Tire System ───────────────────────────────────────
            if F.TireEnabled and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local cf       = Vehicle.PrimaryPart.CFrame
                    local vel      = Seat.AssemblyLinearVelocity
                    local angVel   = Seat.AssemblyAngularVelocity
                    local speed    = vel.Magnitude
                    local localVel = cf:VectorToObjectSpace(vel)
                    local latVel   = localVel.X
                    local fwdVel   = localVel.Z
                    local yawRate  = angVel.Y

                    -- Turn Boost
                    if F.TurnBoostEnabled then
                        local turnInput = 0
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                            turnInput =  1
                        elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then
                            turnInput = -1
                        end
                        if turnInput ~= 0 then
                            local yawDeg = math.deg(math.abs(yawRate))
                            if yawDeg < F.TurnBoostMaxRate then
                                local speedFactor = math.clamp(speed / 30, 0.15, 1.0)
                                local impulse = cf.UpVector
                                    * (turnInput * F.TurnBoostPower * speedFactor * dt * 60)
                                pcall(function() Seat:ApplyAngularImpulse(impulse) end)
                            end
                        else
                            Seat.AssemblyAngularVelocity = Vector3.new(
                                angVel.X, angVel.Y * F.TurnBoostSmoothing, angVel.Z)
                        end
                    end

                    -- Tire Grip
                    if F.TireGripEnabled and math.abs(latVel) > 0.3 then
                        local effectiveGrip = F.TireGrip
                        if F.WheelspinEnabled and speed > F.WheelspinThreshold then
                            local excess = math.clamp(
                                (speed - F.WheelspinThreshold) / 40, 0, 1)
                            effectiveGrip = effectiveGrip
                                * (1 - excess * (1 - F.WheelspinStrength))
                        end
                        local lateralForce = -latVel * effectiveGrip
                            * math.clamp(speed * 0.08, 0.5, 8.0)
                        pcall(function()
                            Seat:ApplyImpulse(cf.RightVector * lateralForce)
                        end)
                    end

                    -- Burnout
                    if F.BurnoutActive and Vehicle.PrimaryPart then
                        if math.abs(fwdVel) < 5 then
                            Seat.AssemblyLinearVelocity = Vector3.new(
                                vel.X * 0.85, vel.Y, vel.Z * 0.85)
                        end
                        local wobble = (math.random() - 0.5) * 0.4
                        Seat.AssemblyAngularVelocity = Vector3.new(
                            angVel.X, angVel.Y + wobble, angVel.Z)
                    end

                    F.TireStats.AngularSpeed = math.floor(math.deg(math.abs(yawRate)))
                    F.TireStats.LatForce     = math.floor(math.abs(latVel) * 10) / 10
                end)
            end

        until true  -- executes exactly once; break exits early for passenger/no-seat

        -- ── Bypass Anti Cheat ────────────────────────────────────
        -- Attempts to undo what common Roblox vehicle anti-cheats do:
        -- 1. Re-anchor parts to stop cheaters → we unanchor them back
        -- 2. Remove network ownership → we reclaim it
        -- 3. Attach BodyMovers/VectorForces to slow the car → we remove them
        -- 4. Set CanCollide=false on parts → we restore it
        -- Runs on a throttled interval (default 1 s) to keep overhead low.
        if F.AnticheatEnabled and Internal.Vehicle then
            if now - F.AC_LastRun >= F.AC_Interval then
                F.AC_LastRun = now
                pcall(function()
                    local Vehicle = Internal.Vehicle
                    local pp      = Vehicle.PrimaryPart

                    -- 1. Reclaim network ownership so we control physics locally
                    if F.AC_NetworkOwner then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent then
                                pcall(function() p:SetNetworkOwner(LocalPlayer) end)
                            end
                        end
                    end

                    -- 2. Unanchor any parts the anticheat may have re-anchored
                    if F.AC_UnanchorAll and not F.Freeze then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent and p.Anchored then
                                pcall(function() p.Anchored = false end)
                            end
                        end
                    end

                    -- 3. Remove BodyMover / VectorForce / BodyVelocity instances
                    --    that anticheat scripts inject to slow or stop the vehicle
                    if F.AC_ClearForces then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent then
                                for _, child in pairs(p:GetChildren()) do
                                    if child:IsA("BodyVelocity")
                                    or child:IsA("BodyAngularVelocity")
                                    or child:IsA("BodyForce")
                                    or child:IsA("BodyGyro")
                                    or child:IsA("BodyPosition")
                                    or child:IsA("BodyThrust") then
                                        -- Only remove if we didn't create it
                                        if child.Name ~= "VoxNoclipAtt"
                                        and child.Name ~= "VoxGravAtt"
                                        and child.Name ~= "GravAtt" then
                                            pcall(function() child:Destroy() end)
                                        end
                                    end
                                end
                            end
                        end
                    end

                    -- 4. Restore CanCollide if anticheat turned it off
                    if F.AC_RestoreCollide and not F.Noclip then
                        for _, p in pairs(Internal.PartsCache) do
                            if p and p.Parent and not p.CanCollide then
                                pcall(function() p.CanCollide = true end)
                            end
                        end
                    end
                end)
            end
        end

        -- ── Freeze (keep anchored every frame) ───────────────
        if F.Freeze then
            pcall(function()
                for _, p in pairs(Internal.PartsCache) do
                    if p and p.Parent and not p.Anchored then
                        p.Anchored = true
                        p.AssemblyLinearVelocity  = Vector3.new(0,0,0)
                        p.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    end
                end
            end)
        end

        -- ── Noclip (keep CanCollide off every frame) ─────────
        if F.Noclip then
            pcall(function()
                for _, p in pairs(Internal.PartsCache) do
                    if p and p.Parent then p.CanCollide = false end
                end
            end)
        end
    end))

    -- ==========================================================
    -- FLIGHT ENGINE  (Heartbeat — uses velocity-based movement,
    --                 NOT SetPrimaryPartCFrame teleporting)
    -- ==========================================================
    --
    -- Design:
    --   • Reads WASD / EQ input each frame
    --   • Builds a desired world-space velocity vector from
    --     the camera's flat (yaw-only) forward/right axes
    --   • Lerps the vehicle's AssemblyLinearVelocity toward that
    --     desired velocity — smooth acceleration & deceleration
    --   • Zeroes out AssemblyAngularVelocity so the hull stays
    --     level and doesn't tumble
    --   • Tilts the hull slightly into turns (roll) and slightly
    --     nose-down at cruise speed (pitch) via CFrame rotation
    --     applied to PrimaryPart — purely cosmetic, no physics
    --   • Optional hover: casts a ray down and applies a small
    --     corrective Y velocity to maintain height
    --   • Optional mouse-steer: keeps hull yaw aligned to camera
    --
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        if not F.FlightEnabled then
            -- When flight turns off, bleed remaining flight velocity
            -- quickly so the vehicle falls naturally
            if F._FlyVel.Magnitude > 0.1 then
                F._FlyVel = F._FlyVel * math.max(0, 1 - dt * 12)
            else
                F._FlyVel = Vector3.new(0, 0, 0)
            end
            return
        end

        pcall(function()
            local Vehicle = Internal.Vehicle
            local Seat    = Internal.Seat
            if not Vehicle or not Seat then return end
            if not Vehicle.PrimaryPart then return end

            local Char = LocalPlayer.Character
            if not Char then return end

            -- Keep character parented inside vehicle so it moves with it
            if Char.Parent ~= Vehicle then
                F.DefaultCharParent = F.DefaultCharParent or Char.Parent
                Char.Parent = Vehicle
            end

            -- ── Camera axes (yaw only — strip pitch/roll) ──────
            local cam       = Workspace.CurrentCamera.CFrame
            local camYaw    = CFrame.new(cam.Position)
                              * CFrame.Angles(0, math.atan2(-cam.LookVector.X,
                                                            -cam.LookVector.Z), 0)
            local camFwd    = camYaw.LookVector   -- flat forward
            local camRight  = camYaw.RightVector  -- flat right
            local worldUp   = Vector3.new(0, 1, 0)

            -- ── Read input ─────────────────────────────────────
            local fwd   = 0
            local right = 0
            local up    = 0

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then fwd   =  1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then fwd   = -1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then right = -1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then right =  1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then up    =  1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then up    = -1 end

            -- ── Desired velocity (world space) ─────────────────
            local hasInput = (fwd ~= 0 or right ~= 0 or up ~= 0)
            local desiredVel

            if hasInput then
                local horizontal = (camFwd * fwd + camRight * right)
                -- normalise only if non-zero
                if horizontal.Magnitude > 0.01 then
                    horizontal = horizontal.Unit * F.FlightSpeed * math.min(
                        math.abs(fwd) + math.abs(right), 1)
                else
                    horizontal = Vector3.new(0,0,0)
                end
                local vertical = worldUp * (up * F.FlightUpSpeed)
                desiredVel = horizontal + vertical
            else
                -- No input → brake toward zero (keep Y so we don't fall)
                desiredVel = Vector3.new(0, 0, 0)
            end

            -- ── Hover height override ──────────────────────────
            local hoverCorrection = 0
            if F.FlightHoverHeight > 0 then
                local rayParams = RaycastParams.new()
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                rayParams.FilterDescendantsInstances = { Vehicle }
                local origin = Vehicle.PrimaryPart.Position
                local result = Workspace:Raycast(
                    origin, Vector3.new(0, -200, 0), rayParams)
                if result then
                    local currentH = origin.Y - result.Position.Y
                    local diff     = F.FlightHoverHeight - currentH
                    -- proportional correction, capped at ±15 st/s
                    hoverCorrection = math.clamp(diff * 3, -15, 15)
                end
                -- blend hover into desired Y
                desiredVel = Vector3.new(
                    desiredVel.X,
                    desiredVel.Y + hoverCorrection,
                    desiredVel.Z)
            end

            -- ── Smooth velocity toward desired ─────────────────
            local accel  = hasInput and F.FlightAccel or F.FlightBrakeStrength
            -- lerp rate: accel studs/s² converted to a 0-1 blend factor
            local blend  = math.clamp(accel * dt, 0, 1)
            F._FlyVel    = F._FlyVel + (desiredVel - F._FlyVel) * blend

            -- Safety: hard-cap velocity so it can never go insane
            local maxSpd = F.FlightSpeed * 2.5
            if F._FlyVel.Magnitude > maxSpd then
                F._FlyVel = F._FlyVel.Unit * maxSpd
            end

            -- ── Apply velocity to physics ──────────────────────
            Seat.AssemblyLinearVelocity  = F._FlyVel
            -- Kill angular velocity so the hull doesn't tumble
            Seat.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

            -- ── Hull orientation ───────────────────────────────
            -- Compute target CFrame: yaw from camera (or keep hull yaw),
            -- small pitch forward at speed, small roll into turns.

            local targetYaw
            if F.FlightMouseSteer then
                -- Hull always faces where the camera looks (flat)
                targetYaw = math.atan2(-cam.LookVector.X, -cam.LookVector.Z)
            else
                -- Hull only yaws when you give horizontal input
                if math.abs(fwd) + math.abs(right) > 0 then
                    local moveDir = camFwd * fwd + camRight * right
                    if moveDir.Magnitude > 0.01 then
                        targetYaw = math.atan2(-moveDir.X, -moveDir.Z)
                    else
                        targetYaw = F._FlyYaw
                    end
                else
                    targetYaw = F._FlyYaw
                end
            end

            -- Smooth yaw transition (wrap-safe lerp)
            local yawDiff = targetYaw - F._FlyYaw
            -- Wrap yawDiff to [-π, π]
            if yawDiff >  math.pi then yawDiff = yawDiff - 2*math.pi end
            if yawDiff < -math.pi then yawDiff = yawDiff + 2*math.pi end
            F._FlyYaw = F._FlyYaw + yawDiff * math.clamp(dt * 7, 0, 1)

            -- Pitch: nose dips slightly at speed (max -8°)
            local speedRatio = math.clamp(F._FlyVel.Magnitude / F.FlightSpeed, 0, 1)
            local pitchAngle = -math.rad(8) * speedRatio * (fwd > 0 and 1 or 0)
            F._FlyPitch = F._FlyPitch + (pitchAngle - F._FlyPitch)
                          * math.clamp(dt * 6, 0, 1)

            -- Roll: bank into turns (max ±18°)
            local rollAngle = math.rad(18) * right * F.FlightRollFactor
                              * math.clamp(F._FlyVel.Magnitude / 20, 0, 1)

            -- Build and apply hull CFrame
            local hullPos = Vehicle.PrimaryPart.Position
            local hullCF  = CFrame.new(hullPos)
                          * CFrame.Angles(0, F._FlyYaw, 0)
                          * CFrame.Angles(F._FlyPitch, 0, -rollAngle)

            -- Use SetPrimaryPartCFrame ONLY for rotation, not translation
            -- (we already moved it via AssemblyLinearVelocity above)
            Vehicle:SetPrimaryPartCFrame(hullCF)
        end)
    end))

