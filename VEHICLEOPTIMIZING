        Callback=function(v)
            SuspData.Enabled=v
            if v then
                if SuspCache.SpringCount>0 then
                    local sum,cnt=0,0
                    for _,o in pairs(SuspCache.OriginalValues) do
                        sum=sum+o.FreeLength; cnt=cnt+1
                    end
                    if cnt>0 then
                        SuspData.OrigBaseHeight=sum/cnt
                        SuspData.CurrentHeight=SuspData.OrigBaseHeight
                    end
                end
                -- Reset live transfer state only; multiplier sliders keep their values
                SuspData.FrontLoad=0; SuspData.RearLoad=0; SuspData.LatLoad=0
                SuspData.PrevLongV=0; SuspData.PrevLatV=0
                Notif("Suspension Configure","Active — "..SuspCache.SpringCount.." springs")
            else
                for _,spring in pairs(SuspCache.Springs) do
                    if spring and spring.Parent then
                        local o=SuspCache.OriginalValues[spring]
                        if o then pcall(function()
                            spring.Stiffness=o.Stiffness; spring.Damping=o.Damping
                            spring.FreeLength=o.FreeLength
                            spring.MinLength=o.MinLength; spring.MaxLength=o.MaxLength
                        end) end
                    end
                end
                Notif("Suspension Configure","OFF — springs restored")
            end
        end})
