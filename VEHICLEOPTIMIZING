    local SusCoreGrp = SusCorePage:Groupbox("Core Settings", "Left")
    SusCoreGrp:AddToggle({ Title="Enable Suspension Override", Default=false, Flag="SuspEnabled",
        Risky=true,
        Description="Must be ON before any suspension changes take effect. "
                 .. "OFF = vehicle springs are completely untouched (default).",
        Callback=function(v)
            SuspData.Enabled = v
            if v then
                -- Compute OrigBaseHeight from the average of all cached original FreeLengths
                -- This is the vehicle's REAL spring height, not a hardcoded guess
                if SuspCache.SpringCount > 0 then
                    local sum   = 0
                    local count = 0
                    local stiffSum  = 0
                    local dampSum   = 0
                    for _, orig in pairs(SuspCache.OriginalValues) do
                        sum      = sum      + orig.FreeLength
                        stiffSum = stiffSum + orig.Stiffness
                        dampSum  = dampSum  + orig.Damping
                        count    = count + 1
                    end
                    if count > 0 then
                        SuspData.OrigBaseHeight = sum / count
                        SuspData.CurrentHeight  = SuspData.OrigBaseHeight
                        -- Also sync the stiffness/damping sliders to the vehicle's real values
                        -- so the first thing the user sees is correct numbers, not defaults
                        local avgStiff = stiffSum / count
                        local avgDamp  = dampSum  / count
                        SuspData.FrontStiff = avgStiff
                        SuspData.RearStiff  = avgStiff
                        SuspData.Damping    = avgDamp
                    end
                end
                Notif("Suspension", "Override ON — using real vehicle spring values as base")
            else
                -- Restore every spring to its exact original cached values
                for i = 1, #SuspCache.Springs do
                    local spring = SuspCache.Springs[i]
                    if spring and spring.Parent then
                        local orig = SuspCache.OriginalValues[spring]
                        if orig then
                            pcall(function()
                                spring.Stiffness  = orig.Stiffness
                                spring.Damping    = orig.Damping
                                spring.FreeLength = orig.FreeLength
                                spring.MinLength  = orig.MinLength
                                spring.MaxLength  = orig.MaxLength
                            end)
                        end
                    end
                end
                Notif("Suspension", "Override OFF — all springs restored to original values")
            end
        end })
    SusCoreGrp:AddParagraph({ Title="How it works",
        Content="Turn ON 'Enable Suspension Override' first. "
             .. "Springs are cached when you enter a vehicle. "
             .. "Turning it OFF restores all springs to their original values." })
