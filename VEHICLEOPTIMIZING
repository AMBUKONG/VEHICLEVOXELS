    -- Color changer
    local PAINT_KW   = {"body","chassis","frame","door","hood","trunk","fender",
                         "bumper","quarter","roof","paint","panel","car"}
    local EXCLUDE_KW = {"window","glass","wheel","tire","rim","light","headlight",
                         "taillight","brake","signal","engine","exhaust","mirror",
                         "handle","seat","interior","dash","steer","neon"}
    local function ApplyColor(color)
        local Vehicle = Internal.Vehicle
        if not Vehicle then Notif("Error","Sit in a vehicle first!"); return end
        local count = 0
        for _, p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                local n = p.Name:lower()
                local skip = false
                for _, kw in pairs(EXCLUDE_KW) do
                    if n:find(kw) then skip = true; break end
                end
                if not skip then
                    for _, kw in pairs(PAINT_KW) do
                        if n:find(kw) then
                            pcall(function()
                                p.Color    = color
                                p.Material = Enum.Material.SmoothPlastic
                            end)
                            count = count + 1; break
                        end
                    end
                end
            end
        end
        Notif("Color Applied", count .. " parts painted")
    end

    -- Gravity
    local function SetGravity(enabled, mode)
        -- Always clean up old force + attachment first
        if F.GravForce then pcall(function() F.GravForce:Destroy() end); F.GravForce = nil end
        if F.GravAtt   then pcall(function() F.GravAtt:Destroy()   end); F.GravAtt   = nil end

        F.GravEnabled = enabled
        F.GravMode    = mode

        if enabled and Internal.Seat then
            pcall(function()
                local att = Instance.new("Attachment")
                att.Name   = "VoxGravAtt"
                att.Parent = Internal.Seat

                local f = Instance.new("VectorForce")
                f.ApplyAtCenterOfMass = true
                f.Attachment0         = att
                f.Parent              = Internal.Seat

                local m = Internal.Seat:GetMass()
                local g = Workspace.Gravity
                if     mode == "Moon"    then f.Force = Vector3.new(0,  g*m*0.18,  0)
                elseif mode == "Heavy"   then f.Force = Vector3.new(0, -g*m*1.5,   0)
                elseif mode == "Zero"    then f.Force = Vector3.new(0,  g*m,       0)
                elseif mode == "Reverse" then f.Force = Vector3.new(0,  g*m*1.8,   0) end

                F.GravForce = f
                F.GravAtt   = att
                Notif("Gravity", mode .. " gravity activated!")
            end)
        else
            Notif("Gravity", "Normal gravity restored!")
        end
    end

    -- Trails
    local function ClearTrails()
        for _, p in pairs(F.TrailParticles) do pcall(function() if p and p.Parent then p:Destroy() end end) end
        for _, a in pairs(F.TrailAttach)    do pcall(function() if a and a.Parent then a:Destroy() end end) end
        F.TrailParticles = {}
        F.TrailAttach    = {}
    end
    local function SetTrail(enabled, ttype)
        if not enabled then
            ClearTrails(); F.TrailEnabled = false
            Notif("Trail", "Disabled!")
            return
        end
        local Vehicle = Internal.Vehicle
        if not Vehicle then Notif("Error","Sit in a vehicle first!"); return end
        ClearTrails()
        F.TrailEnabled = true
        F.TrailType    = ttype

        local wheels = {}
        for _, p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                local n = p.Name:lower()
                if n:find("wheel") or n:find("tire") then
                    table.insert(wheels, p)
                    if #wheels >= 4 then break end
                end
            end
        end
        if #wheels == 0 then
            for _, p in pairs(Vehicle:GetChildren()) do
                if p:IsA("BasePart") then
                    table.insert(wheels, p)
                    if #wheels >= 2 then break end
                end
            end
        end

        for _, w in pairs(wheels) do
            local att = Instance.new("Attachment"); att.Parent = w
            local pe  = Instance.new("ParticleEmitter"); pe.Parent = att
            pe.Enabled  = true
            pe.Rate     = 45
            pe.Lifetime = NumberRange.new(0.8, 1.8)
            pe.Speed    = NumberRange.new(4, 9)
            pe.Size     = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0.45),
                NumberSequenceKeypoint.new(1, 0),
            })
            if ttype == "Rainbow" then
                pe.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,   Color3.new(1,0,0)),
                    ColorSequenceKeypoint.new(0.2,  Color3.new(1,.5,0)),
                    ColorSequenceKeypoint.new(0.4,  Color3.new(1,1,0)),
                    ColorSequenceKeypoint.new(0.6,  Color3.new(0,1,0)),
                    ColorSequenceKeypoint.new(0.8,  Color3.new(0,.5,1)),
                    ColorSequenceKeypoint.new(1,    Color3.new(.5,0,1)),
                })
                pe.LightEmission = 0.5
            elseif ttype == "Fire" then
                pe.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,   Color3.new(1,1,0)),
                    ColorSequenceKeypoint.new(0.5,  Color3.new(1,.5,0)),
                    ColorSequenceKeypoint.new(1,    Color3.new(1,0,0)),
                })
                pe.LightEmission = 0.8
                pe.Texture = "rbxassetid://2416522253"
            elseif ttype == "Ice" then
                pe.Color = ColorSequence.new(Color3.new(.7,.9,1))
                pe.LightEmission = 0.3
                pe.Texture = "rbxassetid://2416522253"
            end
            table.insert(F.TrailParticles, pe)
            table.insert(F.TrailAttach, att)
            DebrisService:AddItem(pe,  12)
            DebrisService:AddItem(att, 12)
        end
        Notif("Trail", ttype .. " trail activated!")
    end

    -- Transformation
    local function SetTransform(enabled, mode)
        if F.TransConn then F.TransConn:Disconnect(); F.TransConn = nil end
        local Vehicle = Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then
            Notif("Error","Sit in a vehicle first!"); return
        end
        if enabled then
            F.TransEnabled = true; F.TransMode = mode
            F.TransCache = {
                Density    = Vehicle.PrimaryPart.Density,
                Friction   = Vehicle.PrimaryPart.Friction,
                Elasticity = Vehicle.PrimaryPart.Elasticity,
                Material   = Vehicle.PrimaryPart.Material,
            }
            if mode == "Plane" then
                Vehicle.PrimaryPart.Density  = 0.1
                Vehicle.PrimaryPart.Friction = 0.1
                F.TransConn = RunService.Stepped:Connect(function()
                    pcall(function()
                        if Vehicle and Vehicle.PrimaryPart then
                            local v = Vehicle.PrimaryPart.AssemblyLinearVelocity
                            Vehicle.PrimaryPart.AssemblyLinearVelocity =
                                Vector3.new(v.X, v.Y * 0.98, v.Z)
                        end
                    end)
                end)
            elseif mode == "Boat" then
                Vehicle.PrimaryPart.Density  = 0.45
                Vehicle.PrimaryPart.Friction = 0.25
            elseif mode == "Tank" then
                Vehicle.PrimaryPart.Density   = 5
                Vehicle.PrimaryPart.Friction  = 1
                Vehicle.PrimaryPart.Material  = Enum.Material.Metal
            end
            Notif("Transform", mode .. " mode activated!")
        else
            F.TransEnabled = false; F.TransMode = "None"
            if F.TransCache.Material then
                pcall(function()
                    Vehicle.PrimaryPart.Density    = F.TransCache.Density
                    Vehicle.PrimaryPart.Friction   = F.TransCache.Friction
                    Vehicle.PrimaryPart.Elasticity = F.TransCache.Elasticity
                    Vehicle.PrimaryPart.Material   = F.TransCache.Material
                end)
            end
            Notif("Transform", "Deactivated!")
        end
    end

    -- Headlights
    local function UpdateHeadlights()
        local Vehicle = Internal.Vehicle
        if not Vehicle then return end
        local count = 0
        for _, l in pairs(Vehicle:GetDescendants()) do
            if l:IsA("PointLight") or l:IsA("SpotLight") then
                pcall(function()
                    l.Enabled    = F.HLEnabled
                    l.Brightness = F.HLEnabled and F.HLBrightness or 0
                    l.Range      = F.HLRadius
                end)
                count = count + 1
            end
        end
        Notif("Headlights", "Applied to " .. count .. " light(s)")
    end

    -- Freeze
    local function SetFreeze(state)
        F.Freeze = state
        if not state then
            -- Unanchor all parts when disabling
            pcall(function()
                for _, p in pairs(Internal.PartsCache) do
                    if p and p.Parent then p.Anchored = false end
                end
            end)
        end
        Notif("Freeze", state and "Vehicle frozen!" or "Vehicle unfrozen!")
    end

    -- Noclip
    local function SetNoclip(state)
        F.Noclip = state
        local Vehicle = Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then return end
        if state then
            -- Create gravity-cancellation force so the car doesn't fall
            if not F.NoclipForce then
                pcall(function()
                    local att = Instance.new("Attachment")
                    att.Name   = "VoxNoclipAtt"
                    att.Parent = Vehicle.PrimaryPart

                    local vf = Instance.new("VectorForce")
                    vf.ApplyAtCenterOfMass = true
                    vf.Attachment0         = att
                    vf.Force = Vector3.new(0,
                        Workspace.Gravity * Vehicle.PrimaryPart:GetMass(), 0)
                    vf.Parent = Vehicle.PrimaryPart

                    F.NoclipForce = vf
                    F.NoclipAtt   = att
                end)
            end
        else
            if F.NoclipForce then pcall(function() F.NoclipForce:Destroy() end); F.NoclipForce = nil end
            if F.NoclipAtt   then pcall(function() F.NoclipAtt:Destroy()   end); F.NoclipAtt   = nil end
            pcall(function()
                for _, p in pairs(Internal.PartsCache) do
                    if p and p.Parent then p.CanCollide = true end
                end
            end)
        end
        Notif("Noclip", state and "Enabled!" or "Disabled!")
    end

    -- Break script
    local function BreakScript()
        Notif("Vehicle Voxels", "Shutting down...", 4)
        pcall(function() SetFB(false) end)
        pcall(function() SetHeli(false) end)
        pcall(function() SetGravity(false, F.GravMode) end)
        pcall(function() SetTrail(false, F.TrailType) end)
        pcall(function() SetNoclip(false) end)
        pcall(function() SetFreeze(false) end)
        if F.TransConn then F.TransConn:Disconnect() end

        for _, c in pairs(connections) do
            pcall(function() if c and c.Disconnect then c:Disconnect() end end)
        end

        task.wait(0.3)
        pcall(function()
            local gui = CoreGui:FindFirstChild("RedOnyx")
            local wat = CoreGui:FindFirstChild("Watermark")
            local hud = CoreGui:FindFirstChild("VoxVehicleInfoHUD")
            if gui then gui:Destroy() end
            if wat then wat:Destroy() end
            if hud then hud:Destroy() end
        end)
        print("[VehicleVoxels] Script terminated.")
    end

