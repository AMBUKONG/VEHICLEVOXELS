    local PAINT_KW   = {"body","chassis","frame","door","hood","trunk","fender","bumper","quarter","roof","paint","panel","car"}
    local EXCLUDE_KW = {"window","glass","wheel","tire","rim","light","headlight","taillight","brake","signal","engine","exhaust","mirror","handle","seat","interior","dash","steer","neon"}
    local function ApplyColor(color)
        local Vehicle = Internal.Vehicle
        if not Vehicle then Notif("Error","Sit in a vehicle first!"); return end
        local count = 0
        for _, p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                local n = p.Name:lower()
                local skip = false
                for _, kw in pairs(EXCLUDE_KW) do if n:find(kw) then skip=true; break end end
                if not skip then
                    for _, kw in pairs(PAINT_KW) do
                        if n:find(kw) then
                            pcall(function() p.Color=color; p.Material=Enum.Material.SmoothPlastic end)
                            count=count+1; break
                        end
                    end
                end
            end
        end
        Notif("Color Applied", count .. " parts painted")
    end

    local function SetGravity(enabled, mode)
        if F.GravForce then pcall(function() F.GravForce:Destroy() end); F.GravForce = nil end
        if F.GravAtt   then pcall(function() F.GravAtt:Destroy()   end); F.GravAtt   = nil end
        F.GravEnabled = enabled; F.GravMode = mode
        if enabled and Internal.Seat then
            pcall(function()
                local att = Instance.new("Attachment"); att.Name="VoxGravAtt"; att.Parent=Internal.Seat
                local f = Instance.new("VectorForce"); f.ApplyAtCenterOfMass=true; f.Attachment0=att; f.Parent=Internal.Seat
                local m = Internal.Seat:GetMass(); local g = Workspace.Gravity
                if     mode=="Moon"    then f.Force=Vector3.new(0, g*m*0.18, 0)
                elseif mode=="Heavy"   then f.Force=Vector3.new(0,-g*m*1.5,  0)
                elseif mode=="Zero"    then f.Force=Vector3.new(0, g*m,      0)
                elseif mode=="Reverse" then f.Force=Vector3.new(0, g*m*1.8,  0) end
                F.GravForce=f; F.GravAtt=att
                Notif("Gravity", mode .. " gravity activated!")
            end)
        else Notif("Gravity", "Normal gravity restored!") end
    end

    local function ClearTrails()
        for _, p in pairs(F.TrailParticles) do pcall(function() if p and p.Parent then p:Destroy() end end) end
        for _, a in pairs(F.TrailAttach)    do pcall(function() if a and a.Parent then a:Destroy() end end) end
        F.TrailParticles = {}; F.TrailAttach = {}
