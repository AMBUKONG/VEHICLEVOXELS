    -- Live stat updater — 10 Hz is plenty for a UI label
    task.spawn(function()
        while task.wait(0.1) do
            pcall(function()
                local yawStr   = F.TireStats.AngularSpeed .. " deg/s"
                local latStr   = F.TireStats.LatForce     .. " st/s"

                -- Derive state string
                local state = "Normal"
                if not F.TireEnabled then
                    state = "System Off"
                elseif F.BurnoutActive then
                    state = "BURNOUT!"
                elseif F.TireStats.LatForce > 8 then
                    state = "Heavy Slide"
                elseif F.TireStats.LatForce > 3 then
                    state = "Sliding"
                elseif F.TireStats.AngularSpeed > 90 then
                    state = "Spinning"
                elseif F.WheelspinEnabled
                    and Internal.Seat
                    and Internal.Seat.AssemblyLinearVelocity.Magnitude
                        > F.WheelspinThreshold then
                    state = "Wheelspin"
                end

                -- Update labels if the library exposes item setters
                if Library.Items then
                    if Library.Items["TireYaw"]   then Library.Items["TireYaw"].Set(yawStr)   end
                    if Library.Items["TireLat"]   then Library.Items["TireLat"].Set(latStr)   end
                    if Library.Items["TireState"] then Library.Items["TireState"].Set(state)  end
                end
            end)
        end
    end)

