    local function IsWheelNameCamber(name)
        local n=name:lower()
        for _,kw in pairs(NONWHEEL_KW) do if n:find(kw,1,true) then return false end end
        for _,kw in pairs(WHEEL_KW)    do if n:find(kw,1,true) then return true  end end
        return false
    end

    local function ScoreWheelPartCamber(part, primCF)
        local score=0; local n=part.Name:lower()
        for _,kw in pairs(NONWHEEL_KW) do if n:find(kw,1,true) then return -999 end end
        for _,kw in pairs(WHEEL_KW)    do if n:find(kw,1,true) then score=score+10; break end end
        if part:IsA("BasePart") then
            if part:IsA("Part") and part.Shape==Enum.PartType.Cylinder then score=score+15 end
            local sz=part.Size
            local mn=math.min(sz.X,sz.Y,sz.Z); local mx=math.max(sz.X,sz.Y,sz.Z)
            if mx/(mn+0.001) > 1.5 then score=score+8 end
            if sz.Magnitude > 0.3 and sz.Magnitude < 10 then score=score+3 end
        end
        for _,child in pairs(part:GetChildren()) do
            if child:IsA("SpecialMesh") then
                local mt=child.MeshType
                if mt==Enum.MeshType.Cylinder or mt==Enum.MeshType.Sphere then score=score+12 end
                local cid=child.MeshId:lower()
                if cid:find("wheel",1,true) or cid:find("tire",1,true) then score=score+8 end
            end
        end
        local lp=primCF:PointToObjectSpace(part.Position)
        if math.abs(lp.X) > 0.8 then score=score+5 end
        if math.abs(lp.Y) < 2.5  then score=score+3 end
        return score
    end

    local function CacheWheelsCamber(Vehicle)
        CamberData.Wheels={}
        if not Vehicle or not Vehicle.PrimaryPart then return end
        local primCF=Vehicle.PrimaryPart.CFrame
        local seen={}; local candidates={}
        pcall(function()
            for _,obj in pairs(Vehicle:GetDescendants()) do
                if obj:IsA("BasePart") then
                    local ok,sc=pcall(ScoreWheelPartCamber,obj,primCF)
                    if ok and sc>=5 then candidates[obj]=sc end
                end
            end
        end)

        local function AddWheel(part,joint,origC0,isDirect,useC1)
            if seen[part] then return end; seen[part]=true
            local lp=primCF:PointToObjectSpace(part.Position)
            local camberAxis=Vector3.new(1,0,0)
            local parentPart=nil
            if joint then pcall(function() parentPart=useC1 and joint.Part1 or joint.Part0 end) end
            if joint and origC0 and parentPart then
                pcall(function()
                    if not parentPart.Parent then return end
                    local r=origC0.RightVector; local u=origC0.UpVector; local l=origC0.LookVector
                    local rip=parentPart.CFrame:VectorToObjectSpace(primCF.RightVector)
                    local rio=Vector3.new(rip:Dot(r),rip:Dot(u),rip:Dot(l))
                    local fip=parentPart.CFrame:VectorToObjectSpace(primCF.LookVector)
                    local fio=Vector3.new(fip:Dot(r),fip:Dot(u),fip:Dot(l))
                    local cand=(math.abs(rio.Y)<=math.abs(fio.Y)) and rio or fio
                    if cand.Magnitude>0.001 then camberAxis=cand.Unit end
                end)
            end
            table.insert(CamberData.Wheels,{
                Part=part,Joint=joint,OrigC0=origC0,UseC1=useC1 or false,
                ParentPart=parentPart,CamberAxis=camberAxis,
                IsFront=lp.Z>0,Side=lp.X>0 and 1 or -1,
                IsDirect=isDirect or false,CurrentAngle=0,PrevApplied=0,Dead=false,
            })
        end

        pcall(function()
            for _,obj in pairs(Vehicle:GetDescendants()) do
                if obj:IsA("Weld") or obj:IsA("Motor6D") then
                    local ok,p0,p1=pcall(function() return obj.Part0,obj.Part1 end)
                    if not ok then p0=nil;p1=nil end
                    local wp,origC,useC1=nil,nil,false
                    if p1 and (candidates[p1] or IsWheelNameCamber(p1.Name)) then wp=p1;origC=obj.C1;useC1=true
                    elseif p0 and (candidates[p0] or IsWheelNameCamber(p0.Name)) then wp=p0;origC=obj.C0;useC1=false end
                    if wp then
                        if seen[wp] then
                            if obj:IsA("Weld") then
                                for i,ex in ipairs(CamberData.Wheels) do
                                    if ex.Part==wp and ex.Joint and not ex.Joint:IsA("Weld") then
                                        CamberData.Wheels[i].Joint=obj
                                        CamberData.Wheels[i].OrigC0=origC
                                        CamberData.Wheels[i].UseC1=useC1
                                    end
                                end
                            end
                        else
                            AddWheel(wp,obj,origC,false,useC1); candidates[wp]=nil
                        end
                    end
                elseif obj:IsA("WeldConstraint") then
                    local p0,p1; pcall(function() p0=obj.Part0;p1=obj.Part1 end)
                    local wp=nil
                    if p1 and (candidates[p1] or IsWheelNameCamber(p1.Name)) then wp=p1
                    elseif p0 and (candidates[p0] or IsWheelNameCamber(p0.Name)) then wp=p0 end
                    if wp then AddWheel(wp,nil,nil,true,false); candidates[wp]=nil end
                end
            end
        end)

        local rem={}
        for p,sc in pairs(candidates) do table.insert(rem,{part=p,score=sc}) end
        table.sort(rem,function(a,b) return a.score>b.score end)
        for _,e in ipairs(rem) do AddWheel(e.part,nil,nil,true,false) end

        local function HasCorner(isFront,side)
            for _,w in ipairs(CamberData.Wheels) do if w.IsFront==isFront and w.Side==side then return true end end
            return false
        end
        for _,c in ipairs({{true,1},{true,-1},{false,1},{false,-1}}) do
            if not HasCorner(c[1],c[2]) then
                local best,bs=nil,-math.huge
                for _,obj in pairs(Vehicle:GetDescendants()) do
                    if obj:IsA("BasePart") and not seen[obj] then
                        local lp=primCF:PointToObjectSpace(obj.Position)
                        if (lp.Z>0)==c[1] and (lp.X>0 and 1 or -1)==c[2] then
                            local n=obj.Name:lower(); local blocked=false
                            for _,kw in pairs(NONWHEEL_KW) do if n:find(kw,1,true) then blocked=true;break end end
                            if not blocked then
                                local s=math.abs(lp.X)*2-math.abs(lp.Y)
                                if obj:IsA("Part") and obj.Shape==Enum.PartType.Cylinder then s=s+20 end
                                if s>bs then bs=s;best=obj end
                            end
                        end
                    end
                end
                if best then
                    local bj,bC,bU=nil,nil,false
                    for _,obj in pairs(Vehicle:GetDescendants()) do
                        if obj:IsA("Weld") or obj:IsA("Motor6D") then
                            local ok,p0,p1=pcall(function() return obj.Part0,obj.Part1 end)
                            if ok then
                                if p1==best then bj=obj;bC=obj.C1;bU=true;break
                                elseif p0==best then bj=obj;bC=obj.C0;bU=false;break end
                            end
                        end
                    end
                    AddWheel(best,bj,bC,bj==nil,bU)
                end
            end
        end

        local cnt=#CamberData.Wheels
        if cnt>0 and cnt%2~=0 then
            local wi,wax=nil,math.huge
            for i,w in ipairs(CamberData.Wheels) do
                local lp=primCF:PointToObjectSpace(w.Part.Position)
                if math.abs(lp.X)<wax then wax=math.abs(lp.X);wi=i end
            end
            if wi then table.remove(CamberData.Wheels,wi) end
        end
    end

    local function RestoreCamber()
        for _,w in pairs(CamberData.Wheels) do
            if w.Joint and w.Joint.Parent and w.OrigC0 then
                pcall(function()
                    if w.UseC1 then w.Joint.C1=w.OrigC0 else w.Joint.C0=w.OrigC0 end
                end)
            end
            w.CurrentAngle=0; w.PrevApplied=0; w.Dead=false
        end
        CamberData.Enabled=false; CamberData.Wheels={}
    end

