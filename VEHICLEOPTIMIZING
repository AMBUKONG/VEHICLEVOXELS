    local function StopFOV()
        if F.FOVConn then F.FOVConn:Disconnect(); F.FOVConn=nil end
        -- Restore original FOV
        pcall(function()
            local cam = Workspace.CurrentCamera
            if cam then
                TweenService:Create(cam, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {FieldOfView = F.FOVOriginal}):Play()
            end
        end)
    end

    local function StartFOV()
        StopFOV()
        F.FOVEnabled = true
        -- Save current FOV as restore point
        pcall(function()
            local cam = Workspace.CurrentCamera
            if cam then F.FOVOriginal = cam.FieldOfView end
        end)
        F.FOVPhase = 0

        F.FOVConn = RunService.Heartbeat:Connect(function(dt)
            if not F.FOVEnabled then return end
            pcall(function()
                local cam = Workspace.CurrentCamera
                if not cam then return end

                local targetFOV = F.FOVMin

                if F.FOVMode == "Pulse" then
                    -- Smooth sine wave between FOVMin and FOVMax
                    F.FOVPhase = F.FOVPhase + dt * F.FOVSpeed
                    local t = (math.sin(F.FOVPhase * math.pi * 2) + 1) / 2  -- 0..1
                    targetFOV = F.FOVMin + (F.FOVMax - F.FOVMin) * t

                elseif F.FOVMode == "Fixed" then
                    -- Stay at FOVMax (no looping, just set and hold)
                    targetFOV = F.FOVMax

                elseif F.FOVMode == "SpeedSync" then
                    -- FOV scales with vehicle speed: slow = FOVMin, fast = FOVMax
                    local Seat = Internal.Seat
                    local spd  = Seat and Seat.AssemblyLinearVelocity.Magnitude or 0
                    -- Reference: 200 st/s = full FOVMax
                    local ratio = math.clamp(spd / 200, 0, 1)
                    targetFOV = F.FOVMin + (F.FOVMax - F.FOVMin) * ratio
                end

                -- Lerp camera FOV toward target (smooth, not jarring)
                local lerpSpeed = F.FOVMode == "Fixed" and 3 or 8
                cam.FieldOfView = cam.FieldOfView
                    + (targetFOV - cam.FieldOfView) * math.clamp(lerpSpeed * dt, 0, 1)
            end)
        end)
        Notif("FOV Changer","Active — Mode: "..F.FOVMode
            .."  Range: "..math.floor(F.FOVMin).."-"..math.floor(F.FOVMax))
    end

    local function SetFOV(enabled)
        F.FOVEnabled = enabled
        if enabled then StartFOV()
        else StopFOV(); Notif("FOV Changer","Disabled — FOV restored") end
    end

