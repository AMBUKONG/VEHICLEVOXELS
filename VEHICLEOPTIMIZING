    local function OnVehicleEntered(Vehicle, Seat)
        if not Vehicle.PrimaryPart then Vehicle.PrimaryPart=Seat end
        SetNetworkOwnership(Vehicle)
        CacheSuspension(Vehicle)
        CacheParts(Vehicle)
        if SuspCache.SpringCount>0 then
            local sum,cnt=0,0
            for _,orig in pairs(SuspCache.OriginalValues) do sum=sum+orig.FreeLength;cnt=cnt+1 end
            if cnt>0 then
                SuspData.OrigBaseHeight=sum/cnt; SuspData.CurrentHeight=SuspData.OrigBaseHeight
            end
        end
        if SuspForce.Enabled then BuildSuspForces() end
        AB.PrevVelocity=Vector3.zero; AB.PrevSurface=nil
        AB.InTransition=false; AB.LastImpactTime=0; AB.VelocityHistory={}
        local now=tick()
        if now-Internal.LastNotifTime>2 then
            Internal.LastNotifTime=now
            Notif("Vehicle Detected",
                Vehicle.Name.."  |  "..SuspCache.SpringCount.." springs  |  "
                ..(Internal.IsDriver and "Driver" or "Passenger"))
        end
    end

