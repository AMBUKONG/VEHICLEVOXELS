    -- ──────────────────────────────────────────────────────────
    -- CAMBER HEARTBEAT
    -- ──────────────────────────────────────────────────────────
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        if not CamberData.Enabled or #CamberData.Wheels==0 then return end
        local Vehicle=Internal.Vehicle; if not Vehicle or not Vehicle.PrimaryPart then return end
        local Seat=Internal.Seat
        local baseDeg=math.clamp(CamberData.Angle,-15,15)
        local dynAdd=0
        if CamberData.DynamicEnabled and Seat then
            pcall(function()
                local vel=Seat.AssemblyLinearVelocity
                local spd=vel.Magnitude
                local lat=math.abs(Vehicle.PrimaryPart.CFrame:VectorToObjectSpace(vel).X)
                local sr=math.clamp(spd/math.max(CamberData.SpeedRef,1),0,1)
                local lr=math.clamp(lat/math.max(CamberData.SpeedRef/3,1),0,1)
                dynAdd=-math.abs(CamberData.DynamicMaxAdd*(sr*CamberData.SpeedFactor+lr*CamberData.LateralFactor))
            end)
        end
        local targetDeg=math.clamp(baseDeg+dynAdd,-15,15)
        local alpha=1-math.exp(-CamberData.LerpSpeed*dt)
        local needPrune=false
        for _,w in ipairs(CamberData.Wheels) do
            local skip=false
            if w.Dead then needPrune=true; skip=true
            elseif not w.Part or not w.Part.Parent then w.Dead=true;needPrune=true;skip=true
            elseif not w.Joint or not w.Joint.Parent then w.Dead=true;needPrune=true;skip=true
            elseif not w.OrigC0 then skip=true
            elseif not(w.Joint:IsA("Weld") or w.Joint:IsA("Motor6D")) then skip=true end
            if not skip then
                pcall(function()
                    w.CurrentAngle=w.CurrentAngle+(targetDeg-w.CurrentAngle)*alpha
                    if math.abs(w.CurrentAngle-targetDeg)<0.005 then w.CurrentAngle=targetDeg end
                    if math.abs(w.CurrentAngle)<0.005 then
                        if w.UseC1 then w.Joint.C1=w.OrigC0 else w.Joint.C0=w.OrigC0 end
                        w.PrevApplied=0; w.CurrentAngle=0; return
                    end
                    if math.abs(w.PrevApplied-w.CurrentAngle)>8 then w.PrevApplied=w.CurrentAngle end
                    local live=w.UseC1 and w.Joint.C1 or w.Joint.C0
                    local pr=math.rad(w.PrevApplied)*w.Side
                    local nr=math.rad(w.CurrentAngle)*w.Side
                    local pt=CFrame.fromAxisAngle(w.CamberAxis,pr)
                    local nt=CFrame.fromAxisAngle(w.CamberAxis,nr)
                    local lp=live.Position
                    local lr=CFrame.fromMatrix(Vector3.zero,live.RightVector,live.UpVector)
                    local newCF=CFrame.new(lp)*(lr*pt:Inverse()*nt)
                    if w.UseC1 then w.Joint.C1=newCF else w.Joint.C0=newCF end
                    w.PrevApplied=w.CurrentAngle
                end)
            end
        end
        if needPrune then
            for i=#CamberData.Wheels,1,-1 do
                if CamberData.Wheels[i].Dead then table.remove(CamberData.Wheels,i) end
            end
        end
    end))

    -- ──────────────────────────────────────────────────────────
    -- ──────────────────────────────────────────────────────────
    -- SUSPENSION CONFIGURE — STABLE REALISTIC STEPPED LOOP
    --
    --  All forces work as MULTIPLIERS on the vehicle's own
    --  original spring values — we never inject raw numbers.
    --  FreeLength offsets are capped to tiny ranges so the car
    --  cannot be flung regardless of slider position.
    --
    --  Physics modelled:
    --   • Stiffness multiplier (front/rear biased)
    --   • Damping multiplier + speed-sensitive boost
    --   • Squat (rear) / Dive (front) from longitudinal accel
    --   • Body roll from lateral accel
    --   • ARB: extra stiffness on compressed corner
    --   • Drift mode: softer rear
    --   • Hydraulics, bounce, preload — all tiny offsets
    -- ──────────────────────────────────────────────────────────
    table.insert(connections, RunService.Stepped:Connect(function(_,dt)
        if not SuspData.Enabled or SuspCache.SpringCount==0 then return end
        local Vehicle=Internal.Vehicle; local Seat=Internal.Seat
        if not Vehicle or not Seat or not Vehicle.PrimaryPart then return end
        pcall(function()
            local primCF = Vehicle.PrimaryPart.CFrame
            local vel    = Seat.AssemblyLinearVelocity
            local spd    = vel.Magnitude
            local localV = primCF:VectorToObjectSpace(vel)
            local longV  = -localV.Z   -- positive = forward
            local latV   =  localV.X   -- positive = rightward

            -- ── Bounce ───────────────────────────────────────────
            if SuspData.BounceEnabled then
                SuspData.BouncePhase = SuspData.BouncePhase
                    + dt * SuspData.BounceFreq * math.pi * 2
            end

            -- ── Weight transfer (velocity delta, heavily clamped) ─
            -- We measure how much the velocity changed since last frame
            -- then normalise to -1..1. Max meaningful change ~20 st/s per frame.
            local longDelta = math.clamp((longV - SuspData.PrevLongV) / (dt + 0.001), -20, 20) / 20
            local latDelta  = math.clamp((latV  - SuspData.PrevLatV)  / (dt + 0.001), -20, 20) / 20
            SuspData.PrevLongV = longV
            SuspData.PrevLatV  = latV

            local lerpT = math.clamp(SuspData.LoadLerp * 60 * dt, 0, 1)
            -- longDelta > 0 = accelerating → rear load increases
            -- longDelta < 0 = braking      → front load increases
            SuspData.FrontLoad = SuspData.FrontLoad + (-longDelta - SuspData.FrontLoad) * lerpT
            SuspData.RearLoad  = SuspData.RearLoad  + ( longDelta - SuspData.RearLoad)  * lerpT
            SuspData.LatLoad   = SuspData.LatLoad   + ( latDelta  - SuspData.LatLoad)   * lerpT

            -- Clamp loads to -1..1 (belt-and-suspenders safety)
            SuspData.FrontLoad = math.clamp(SuspData.FrontLoad, -1, 1)
            SuspData.RearLoad  = math.clamp(SuspData.RearLoad,  -1, 1)
            SuspData.LatLoad   = math.clamp(SuspData.LatLoad,   -1, 1)

            -- ── Speed-sensitive damping multiplier ────────────────
            local speedRatio    = math.clamp(spd / math.max(SuspData.SpeedRef, 1), 0, 1)
            local speedDampMult = SuspData.SpeedDamping
                and (1 + (SuspData.SpeedDampMax - 1) * speedRatio)
                or  1.0

            -- ── Ride height target (tiny studs) ───────────────────
            local base    = SuspData.OrigBaseHeight
            local hTarget = SuspData.HydroEnabled
                and base * SuspData.HydroPressure + SuspData.Height + SuspData.Preload
                or  base + SuspData.Height + SuspData.Preload
            -- Very slow lerp so hydraulic height change is gentle
            local hydLerp = math.clamp(SuspData.HydroSpeed * 60 * dt, 0, 1)
            SuspData.CurrentHeight = SuspData.CurrentHeight
                + (hTarget - SuspData.CurrentHeight) * hydLerp

            -- ── Per-spring update ─────────────────────────────────
            for _, spring in pairs(SuspCache.Springs) do
                if spring and spring.Parent then
                    pcall(function()
                        local orig = SuspCache.OriginalValues[spring]
                        if not orig then return end

                        -- Identify corner
                        local isFront, isLeft = false, false
                        local att = spring.Attachment0 or spring.Attachment1
                        if att and att.Parent then
                            local lp = primCF:PointToObjectSpace(att.WorldPosition)
                            isFront  = lp.Z > 0
                            isLeft   = lp.X < 0
                        end

                        -- ── Stiffness multiplier ──────────────────
                        local stiffMult = SuspData.StiffMult
                        if isFront then
                            stiffMult = stiffMult * (1 + SuspData.FrontBias * 0.5)
                        else
                            stiffMult = stiffMult * (1 + SuspData.RearBias  * 0.5)
                        end
                        if SuspData.DriftMode then
                            stiffMult = isFront and stiffMult * 1.2 or stiffMult * 0.55
                        end

                        -- ARB: add up to 50 % extra stiffness on the compressed side
                        if SuspData.ARB then
                            local sideCompressed = (SuspData.LatLoad > 0) == isLeft
                            if sideCompressed then
                                stiffMult = stiffMult
                                    + SuspData.ARB_Str * math.abs(SuspData.LatLoad) * 0.5
                            end
                        end

                        -- Clamp multiplier: 0.05 (very soft) … 4.0 (very stiff)
                        stiffMult = math.clamp(stiffMult, 0.05, 4.0)

                        -- ── Damping multiplier ────────────────────
                        local dampMult = math.clamp(
                            SuspData.DampMult * speedDampMult, 0.1, 6.0)

                        spring.Stiffness = math.clamp(orig.Stiffness * stiffMult, 10, 60000)
                        spring.Damping   = math.clamp(orig.Damping   * dampMult,  1,  8000)

                        -- ── FreeLength offsets (all tiny, capped) ─────────────
                        local offset = 0

                        -- Dive: front compresses under braking
                        if isFront and SuspData.DiveEnabled then
                            -- FrontLoad > 0 when braking → shorten front springs
                            offset = offset - SuspData.FrontLoad * SuspData.DiveAmt
                        end
                        -- Squat: rear compresses under acceleration
                        if not isFront and SuspData.SquatEnabled then
                            -- RearLoad > 0 when accelerating → shorten rear springs
                            offset = offset - SuspData.RearLoad * SuspData.SquatAmt
                        end
                        -- Body roll: outside wheel compresses
                        if SuspData.RollEnabled then
                            local sideSign = isLeft and -1 or 1
                            offset = offset - sideSign * SuspData.LatLoad * SuspData.RollAmt
                        end

                        -- Bounce
                        if SuspData.BounceEnabled then
                            offset = offset + math.sin(SuspData.BouncePhase)
                                * SuspData.BounceAmplitude
                        end

                        -- Hard cap on total offset: never more than ±0.25 studs
                        offset = math.clamp(offset, -0.25, 0.25)

                        -- Final FreeLength: base + height offset + weight offset
                        -- Clamped tightly to original ± 2 studs (absolute safety net)
                        local finalLen = math.clamp(
                            SuspData.CurrentHeight + offset,
                            orig.FreeLength - 2.0,
                            orig.FreeLength + 2.0)

                        -- Also respect spring min/max
                        finalLen = math.clamp(finalLen,
                            orig.MinLength + 0.01,
                            orig.MaxLength - 0.01)

                        spring.FreeLength = finalLen
                    end)
                end
            end
        end)
    end))

    -- ──────────────────────────────────────────────────────────
    -- MAIN HEARTBEAT
    -- ──────────────────────────────────────────────────────────
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        local now=tick()
        pcall(UpdateVehicleRef,now)
        pcall(SuspForceTick)   -- spring-damper per wheel

        local Seat=Internal.Seat; local Vehicle=Internal.Vehicle
        if not Vehicle then return end

        repeat
            if not Seat then break end

            -- Anti-Bounce
            if AB.Enabled then
                pcall(function()
                    local cur=Seat.AssemblyLinearVelocity
                    local prev=AB.PrevVelocity
                    local dv=(cur-prev).Magnitude
                    if dv>AB.ImpactThreshold then AB.LastImpactTime=now end
                    table.insert(AB.VelocityHistory,cur)
                    if #AB.VelocityHistory>AB.SmoothingFrames then table.remove(AB.VelocityHistory,1) end
                    if dv>AB.MaxVelocityChange and prev.Magnitude>1e-4 then
                        Seat.AssemblyLinearVelocity=prev+SafeUnit(cur-prev)*AB.MaxVelocityChange
                    end
                    if AB.SurfaceSmoothing and now-AB.LastRaycastTime>=0.05 then
                        AB.LastRaycastTime=now
                        pcall(function()
                            local rp=RaycastParams.new()
                            rp.FilterType=Enum.RaycastFilterType.Exclude
                            rp.FilterDescendantsInstances={Vehicle}
                            local res=Workspace:Raycast(Seat.Position,Vector3.new(0,-10,0),rp)
                            if res then
                                local cs={Instance=res.Instance,Height=res.Position.Y}
                                local ps=AB.PrevSurface
                                if ps then
                                    if cs.Instance~=ps.Instance or math.abs(cs.Height-ps.Height)>0.5 then
                                        AB.InTransition=true; AB.TransitionStart=now
                                        local v=Seat.AssemblyLinearVelocity
                                        Seat.AssemblyLinearVelocity=Vector3.new(v.X,v.Y*AB.TransitionDampening,v.Z)
                                        Seat.AssemblyAngularVelocity=Seat.AssemblyAngularVelocity*(AB.TransitionDampening*0.4)
                                    end
                                end
                                AB.PrevSurface=cs
                            end
                        end)
                    end
                    if AB.InTransition then
                        if now-AB.TransitionStart<0.2 then Seat.AssemblyLinearVelocity=Seat.AssemblyLinearVelocity*0.96
                        else AB.InTransition=false end
                    end
                    local tsi=now-AB.LastImpactTime
                    if tsi<AB.StabilizationTime then
                        local p=tsi/AB.StabilizationTime
                        Seat.AssemblyLinearVelocity =Seat.AssemblyLinearVelocity *(AB.VelocityDampening+(1-AB.VelocityDampening)*p)
                        Seat.AssemblyAngularVelocity=Seat.AssemblyAngularVelocity*(AB.AngularDampening +(1-AB.AngularDampening)*p)
                        if Vehicle.PrimaryPart then
                            local up=Vehicle.PrimaryPart.CFrame.UpVector
                            local tilt=math.acos(math.clamp(up:Dot(Vector3.new(0,1,0)),-1,1))
                            if tilt>math.rad(8) then
                                local cross=up:Cross(Vector3.new(0,1,0))
                                if cross.Magnitude>1e-4 then
                                    pcall(function() Seat:ApplyAngularImpulse(cross.Unit*(tilt*28*(1-p))) end)
                                end
                            end
                        end
                    end
                    AB.PrevVelocity=Seat.AssemblyLinearVelocity
                end)
            end

            -- Auto Speed
            if F.AutoSpeed and Internal.IsDriver then
                pcall(function()
                    local vel=Seat.AssemblyLinearVelocity
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        local newV=vel+Seat.CFrame.LookVector*(F.AutoAccel*dt*60)
                        if F.MaxSpeed~=math.huge and F.MaxSpeed>0 then
                            local h=Vector3.new(newV.X,0,newV.Z)
                            if h.Magnitude>F.MaxSpeed then
                                local c=h.Unit*F.MaxSpeed
                                newV=Vector3.new(c.X,newV.Y,c.Z)
                            end
                        end
                        newV=Vector3.new(newV.X,math.clamp(newV.Y,-50,50),newV.Z)
                        Seat.AssemblyLinearVelocity=newV
                    end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        local bf=math.clamp(1-F.AutoBrake*0.1,0,1)
                        Seat.AssemblyLinearVelocity=vel*Vector3.new(bf,0.98,bf)
                    end
                end)
            end

            -- Traction
            if F.Traction and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local cf=Vehicle.PrimaryPart.CFrame
                    local lv=cf:VectorToObjectSpace(Seat.AssemblyLinearVelocity).X
                    if math.abs(lv)>0.5 then
                        Seat:ApplyImpulse(cf.RightVector*-lv*(1-F.TractionGrip)*50)
                    end
                end)
            end

            -- Brake Override
            if F.BrakeOverride and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local pp=Vehicle.PrimaryPart; local cf=pp.CFrame
                    local blend=math.clamp(dt*20,0,1)
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        local cur=pp.AssemblyLinearVelocity; local des=cf.LookVector*F.BrakeForce
                        pp.AssemblyLinearVelocity=Vector3.new(cur.X+(des.X-cur.X)*blend,cur.Y,cur.Z+(des.Z-cur.Z)*blend)
                        pcall(function() Seat.Throttle=1 end)
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        local cur=pp.AssemblyLinearVelocity; local des=-cf.LookVector*(F.BrakeForce*0.55)
                        pp.AssemblyLinearVelocity=Vector3.new(cur.X+(des.X-cur.X)*blend,cur.Y,cur.Z+(des.Z-cur.Z)*blend)
                        pcall(function() Seat.Throttle=-1 end)
                    else
                        local bf=math.pow(0.01,dt); local cur=pp.AssemblyLinearVelocity
                        pp.AssemblyLinearVelocity=Vector3.new(cur.X*bf,cur.Y,cur.Z*bf)
                        pcall(function() Seat.Throttle=0 end)
                    end
                    local ti=0
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then ti=-1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then ti=1 end
                    if ti~=0 then
                        if math.deg(math.abs(pp.AssemblyAngularVelocity.Y))<100 then
                            pp:ApplyAngularImpulse(cf.UpVector*(ti*12*dt*60))
                        end
                        pcall(function() Seat.Steer=-ti end)
                    else
                        local av=pp.AssemblyAngularVelocity
                        pp.AssemblyAngularVelocity=Vector3.new(av.X,av.Y*math.pow(0.001,dt),av.Z)
                        pcall(function() Seat.Steer=0 end)
                    end
                end)
            end

            -- Bypass Brake
            if F.BypassBrakeEnabled and Internal.IsDriver then
                pcall(function()
                    local t,s=0,0
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then t=1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then t=-1 end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then s=1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then s=-1 end
                    Seat.Throttle=t*F.BypassThrottlePower; Seat.Steer=s*F.BypassSteerPower
                end)
            end

            -- Tire System
            if F.TireEnabled and Vehicle.PrimaryPart and Internal.IsDriver then
                pcall(function()
                    local cf=Vehicle.PrimaryPart.CFrame
                    local vel=Seat.AssemblyLinearVelocity; local av=Seat.AssemblyAngularVelocity
                    local spd=vel.Magnitude; local lv=cf:VectorToObjectSpace(vel)
                    local lat=lv.X; local yaw=av.Y
                    if F.TurnBoostEnabled then
                        local ti=0
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then ti=1
                        elseif UserInputService:IsKeyDown(Enum.KeyCode.D) then ti=-1 end
                        if ti~=0 then
                            if math.deg(math.abs(yaw))<F.TurnBoostMaxRate then
                                local sf=math.clamp(spd/30,0.15,1.0)
                                pcall(function() Seat:ApplyAngularImpulse(cf.UpVector*(ti*F.TurnBoostPower*sf*dt*60)) end)
                            end
                        else
                            Seat.AssemblyAngularVelocity=Vector3.new(av.X,av.Y*F.TurnBoostSmoothing,av.Z)
                        end
                    end
                    if F.TireGripEnabled and math.abs(lat)>0.3 then
                        local eg=F.TireGrip
                        if F.WheelspinEnabled and spd>F.WheelspinThreshold then
                            local ex=math.clamp((spd-F.WheelspinThreshold)/40,0,1)
                            eg=eg*(1-ex*(1-F.WheelspinStrength))
                        end
                        pcall(function() Seat:ApplyImpulse(cf.RightVector*(-lat*eg*math.clamp(spd*0.08,0.5,8.0))) end)
                    end
                    if F.BurnoutActive and Vehicle.PrimaryPart then
                        if math.abs(lv.Z)<5 then
                            Seat.AssemblyLinearVelocity=Vector3.new(vel.X*0.85,vel.Y,vel.Z*0.85)
                        end
                        Seat.AssemblyAngularVelocity=Vector3.new(av.X,av.Y+(math.random()-0.5)*0.4,av.Z)
                    end
                    F.TireStats.AngularSpeed=math.floor(math.deg(math.abs(yaw)))
                    F.TireStats.LatForce=math.floor(math.abs(lat)*10)/10
                end)
            end
        until true

        -- Anticheat
        if F.AnticheatEnabled and Internal.Vehicle then
            if now-F.AC_LastRun>=F.AC_Interval then
                F.AC_LastRun=now
                pcall(function()
                    if F.AC_NetworkOwner then
                        for _,p in pairs(Internal.PartsCache) do
                            if p and p.Parent then pcall(function() p:SetNetworkOwner(LocalPlayer) end) end
                        end
                    end
                    if F.AC_UnanchorAll and not F.Freeze then
                        for _,p in pairs(Internal.PartsCache) do
                            if p and p.Parent and p.Anchored then pcall(function() p.Anchored=false end) end
                        end
                    end
                    if F.AC_ClearForces then
                        local PROTECTED={"VoxNoclipAtt","VoxGravAtt","GravAtt","VoxSuspForce","VoxSuspForceAtt"}
                        local pset={}; for _,n in pairs(PROTECTED) do pset[n]=true end
                        for _,p in pairs(Internal.PartsCache) do
                            if p and p.Parent then
                                for _,child in pairs(p:GetChildren()) do
                                    if not pset[child.Name] and (
                                        child:IsA("BodyVelocity") or child:IsA("BodyAngularVelocity")
                                        or child:IsA("BodyForce") or child:IsA("BodyGyro")
                                        or child:IsA("BodyPosition") or child:IsA("BodyThrust")) then
                                        pcall(function() child:Destroy() end)
                                    end
                                end
                            end
                        end
                    end
                    if F.AC_RestoreCollide and not F.Noclip then
                        for _,p in pairs(Internal.PartsCache) do
                            if p and p.Parent and not p.CanCollide then
                                pcall(function() p.CanCollide=true end)
                            end
                        end
                    end
                end)
            end
        end

        if F.Freeze then
            pcall(function()
                for _,p in pairs(Internal.PartsCache) do
                    if p and p.Parent and not p.Anchored then
                        p.Anchored=true
                        p.AssemblyLinearVelocity=Vector3.zero
                        p.AssemblyAngularVelocity=Vector3.zero
                    end
                end
            end)
        end

        if F.Noclip then
            pcall(function()
                for _,p in pairs(Internal.PartsCache) do
                    if p and p.Parent then p.CanCollide=false end
                end
            end)
        end
    end))

    -- ──────────────────────────────────────────────────────────
    -- FLIGHT ENGINE
    -- ──────────────────────────────────────────────────────────
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        if not F.FlightEnabled then
            if F._FlyVel.Magnitude>0.1 then F._FlyVel=F._FlyVel*math.max(0,1-dt*12)
            else F._FlyVel=Vector3.zero end
            return
        end
        pcall(function()
            local Vehicle=Internal.Vehicle; local Seat=Internal.Seat
            if not Vehicle or not Seat or not Vehicle.PrimaryPart then return end
            local Char=LocalPlayer.Character; if not Char then return end
            if Char.Parent~=Vehicle then
                F.DefaultCharParent=F.DefaultCharParent or Char.Parent
                Char.Parent=Vehicle
            end
            local cam=Workspace.CurrentCamera.CFrame
            local yaw=CFrame.new(cam.Position)*CFrame.Angles(0,math.atan2(-cam.LookVector.X,-cam.LookVector.Z),0)
            local fwd,right,up=0,0,0
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then fwd=1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then fwd=-1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then right=-1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then right=1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then up=1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then up=-1 end
            local hasInput=(fwd~=0 or right~=0 or up~=0)
            local desVel
            if hasInput then
                local h=yaw.LookVector*fwd+yaw.RightVector*right
                if h.Magnitude>0.01 then h=h.Unit*F.FlightSpeed*math.min(math.abs(fwd)+math.abs(right),1)
                else h=Vector3.zero end
                desVel=h+Vector3.new(0,1,0)*(up*F.FlightUpSpeed)
            else desVel=Vector3.zero end
            if F.FlightHoverHeight>0 then
                local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Exclude
                rp.FilterDescendantsInstances={Vehicle}
                local res=Workspace:Raycast(Vehicle.PrimaryPart.Position,Vector3.new(0,-200,0),rp)
                if res then
                    local diff=F.FlightHoverHeight-(Vehicle.PrimaryPart.Position.Y-res.Position.Y)
                    desVel=Vector3.new(desVel.X,desVel.Y+math.clamp(diff*3,-15,15),desVel.Z)
                end
            end
            local accel=hasInput and F.FlightAccel or F.FlightBrakeStrength
            F._FlyVel=F._FlyVel+(desVel-F._FlyVel)*math.clamp(accel*dt,0,1)
            local ms=F.FlightSpeed*2.5
            if F._FlyVel.Magnitude>ms then F._FlyVel=F._FlyVel.Unit*ms end
            Seat.AssemblyLinearVelocity=F._FlyVel; Seat.AssemblyAngularVelocity=Vector3.zero
            local tYaw
            if F.FlightMouseSteer then tYaw=math.atan2(-cam.LookVector.X,-cam.LookVector.Z)
            else
                if math.abs(fwd)+math.abs(right)>0 then
                    local md=yaw.LookVector*fwd+yaw.RightVector*right
                    tYaw=md.Magnitude>0.01 and math.atan2(-md.X,-md.Z) or F._FlyYaw
                else tYaw=F._FlyYaw end
            end
            local yd=tYaw-F._FlyYaw
            if yd>math.pi then yd=yd-2*math.pi elseif yd<-math.pi then yd=yd+2*math.pi end
            F._FlyYaw=F._FlyYaw+yd*math.clamp(dt*7,0,1)
            local sr=math.clamp(F._FlyVel.Magnitude/F.FlightSpeed,0,1)
            local pitch=-math.rad(8)*sr*(fwd>0 and 1 or 0)
            F._FlyPitch=F._FlyPitch+(pitch-F._FlyPitch)*math.clamp(dt*6,0,1)
            local roll=math.rad(18)*right*F.FlightRollFactor*math.clamp(F._FlyVel.Magnitude/20,0,1)
            Vehicle:SetPrimaryPartCFrame(CFrame.new(Vehicle.PrimaryPart.Position)
                *CFrame.Angles(0,F._FlyYaw,0)*CFrame.Angles(F._FlyPitch,0,-roll))
        end)
    end))

