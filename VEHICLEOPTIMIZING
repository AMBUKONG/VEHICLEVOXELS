    local function SetTrail(en,ttype)
        if not en then ClearTrails(); F.TrailEnabled=false; Notif("Trail","Disabled!"); return end
        local Vehicle=Internal.Vehicle; if not Vehicle then Notif("Error","No vehicle!"); return end
        ClearTrails(); F.TrailEnabled=true; F.TrailType=ttype
        local wheels={}
        for _,p in pairs(Vehicle:GetDescendants()) do
            if p:IsA("BasePart") then
                local n=p.Name:lower()
                if n:find("wheel") or n:find("tire") then table.insert(wheels,p); if #wheels>=4 then break end end
            end
        end
        if #wheels==0 then
            for _,p in pairs(Vehicle:GetChildren()) do
                if p:IsA("BasePart") then table.insert(wheels,p); if #wheels>=2 then break end end
            end
        end
        for _,w in pairs(wheels) do
            local att=Instance.new("Attachment"); att.Parent=w
            local pe=Instance.new("ParticleEmitter"); pe.Parent=att
            pe.Enabled=true; pe.Rate=45; pe.Lifetime=NumberRange.new(0.8,1.8); pe.Speed=NumberRange.new(4,9)
            pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.45),NumberSequenceKeypoint.new(1,0)})
            if ttype=="Rainbow" then
                pe.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,Color3.new(1,0,0)),ColorSequenceKeypoint.new(0.2,Color3.new(1,.5,0)),
                    ColorSequenceKeypoint.new(0.4,Color3.new(1,1,0)),ColorSequenceKeypoint.new(0.6,Color3.new(0,1,0)),
                    ColorSequenceKeypoint.new(0.8,Color3.new(0,.5,1)),ColorSequenceKeypoint.new(1,Color3.new(.5,0,1)),
                }); pe.LightEmission=0.5
            elseif ttype=="Fire" then
                pe.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,Color3.new(1,1,0)),ColorSequenceKeypoint.new(0.5,Color3.new(1,.5,0)),
                    ColorSequenceKeypoint.new(1,Color3.new(1,0,0)),
                }); pe.LightEmission=0.8; pe.Texture="rbxassetid://2416522253"
            elseif ttype=="Ice" then
                pe.Color=ColorSequence.new(Color3.new(.7,.9,1)); pe.LightEmission=0.3; pe.Texture="rbxassetid://2416522253"
            end
            table.insert(F.TrailParticles,pe); table.insert(F.TrailAttach,att)
            DebrisService:AddItem(pe,12); DebrisService:AddItem(att,12)
        end
        Notif("Trail",ttype.." trail activated!")
    end

    local function SetTransform(en,mode)
        if F.TransConn then F.TransConn:Disconnect(); F.TransConn=nil end
        local Vehicle=Internal.Vehicle
        if not Vehicle or not Vehicle.PrimaryPart then Notif("Error","No vehicle!"); return end
        if en then
            F.TransEnabled=true; F.TransMode=mode
            F.TransCache={Density=Vehicle.PrimaryPart.Density,Friction=Vehicle.PrimaryPart.Friction,
                Elasticity=Vehicle.PrimaryPart.Elasticity,Material=Vehicle.PrimaryPart.Material}
            if mode=="Plane" then
                Vehicle.PrimaryPart.Density=0.1; Vehicle.PrimaryPart.Friction=0.1
                F.TransConn=RunService.Stepped:Connect(function()
                    pcall(function()
                        if Vehicle and Vehicle.PrimaryPart then
                            local v=Vehicle.PrimaryPart.AssemblyLinearVelocity
                            Vehicle.PrimaryPart.AssemblyLinearVelocity=Vector3.new(v.X,v.Y*0.98,v.Z)
                        end
                    end)
                end)
            elseif mode=="Boat" then Vehicle.PrimaryPart.Density=0.45; Vehicle.PrimaryPart.Friction=0.25
            elseif mode=="Tank" then Vehicle.PrimaryPart.Density=5; Vehicle.PrimaryPart.Friction=1; Vehicle.PrimaryPart.Material=Enum.Material.Metal end
            Notif("Transform",mode.." activated!")
        else
            F.TransEnabled=false; F.TransMode="None"
            if F.TransCache.Material then
                pcall(function()
                    Vehicle.PrimaryPart.Density=F.TransCache.Density; Vehicle.PrimaryPart.Friction=F.TransCache.Friction
                    Vehicle.PrimaryPart.Elasticity=F.TransCache.Elasticity; Vehicle.PrimaryPart.Material=F.TransCache.Material
                end)
            end
            Notif("Transform","Deactivated!")
        end
    end

